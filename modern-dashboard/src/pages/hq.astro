---

<QaHqLayout title="CORE QA Headquarters">
  <main class="hq-shell" id="hq-main">
    <aside class="hq-sidebar" aria-label="CORE QA headquarters navigation">
      <div class="hq-brand">
        <span class="brand-mark" aria-hidden="true">QA</span>
        <div>
          <p class="eyebrow">CORE</p>
          <h1>QA Headquarters</h1>
        </div>
      </div>

      <nav class="hq-nav" aria-label="HQ modules">
        <a class="active" href="#boards">Release boards</a>
        <a href="#kb">Knowledge base</a>
        <a href="#automation">Automation bench</a>
        <a href="#ai">AI summary</a>
        <a href="#status">Operations status</a>
        <a href="#access">Access control</a>
      </nav>

      <div class="side-status">
        <p class="eyebrow">Current pilot</p>
        <strong>v3001.124.0</strong>
        <span>Cloudflare migration target</span>
      </div>
    </aside>

    <section class="hq-workbench" aria-label="CORE QA HQ workbench">
      <header class="command-strip">
        <div>
          <p class="eyebrow">Test bench</p>
          <h2>CORE QA operating hub</h2>
          <p class="command-summary">Central workspace for release dashboards, test knowledge, automation evidence, AI triage, and service health.</p>
        </div>
        <div class="command-actions" aria-label="HQ quick links">
          <a href="#boards">Boards</a>
          <a href="#automation">Runbook</a>
          <a href="#specs">Specs</a>
        </div>
      </header>

      <section class="status-grid" aria-label="Operational status snapshot">
        {statusCards.map((card) => (
          <article class={`status-card ${card.tone}`}>
            <span>{card.label}</span>
            <strong>{card.value}</strong>
            <p>{card.detail}</p>
          </article>
        ))}
      </section>

      <section class="module-panel board-module" id="boards">
        <div class="module-heading">
          <div>
            <p class="eyebrow">Release boards</p>
            <h2>Dashboard command center</h2>
          </div>
          <span class="module-pill">3 releases tracked</span>
        </div>

        <div class="board-tabs" role="list" aria-label="Release dashboard shortcuts">
          {releaseBoards.map((board) => (
            <a class={board.status === "Current" ? "board-tab current" : "board-tab"} href={board.modernUrl}>
              <span>{board.label}</span>
              <strong>{board.release}</strong>
              <em>{board.status}</em>
            </a>
          ))}
        </div>

        <div class="board-grid">
          {releaseBoards.map((board) => (
            <article class={board.status === "Current" ? "board-card current" : "board-card"}>
              <div class="board-card-top">
                <div>
                  <p class="eyebrow">{board.state}</p>
                  <h3>{board.release}</h3>
                </div>
                <span>{board.status}</span>
              </div>
              <p>{board.summary}</p>
              <dl>
                <div>
                  <dt>Repository</dt>
                  <dd>{board.repo}</dd>
                </div>
              </dl>
              <div class="card-actions">
                <a href={board.modernUrl}>Modern board</a>
                <a href={board.url}>Legacy board</a>
              </div>
            </article>
          ))}
        </div>

        <article class="board-preview">
          <div class="preview-heading">
            <div>
              <p class="eyebrow">Current preview</p>
              <h3>v3001.124.0 modern dashboard</h3>
            </div>
            <a href="https://dewankabir009.github.io/jira-board-v3001-124-0/modern/">Open full board</a>
          </div>
          <iframe title="v3001.124.0 modern board preview" src="https://dewankabir009.github.io/jira-board-v3001-124-0/modern/" loading="lazy"></iframe>
        </article>
      </section>

      <section class="module-panel kb-module" id="kb">
        <div class="module-heading">
          <div>
            <p class="eyebrow">Knowledge base</p>
            <h2>Test flow library</h2>
          </div>
          <span class="module-pill">SPEC-HQ-04 active</span>
        </div>

        <div class="kb-console">
          <article class="kb-spotlight">
            <div>
              <p class="eyebrow">Featured flow</p>
              <h3>{knowledgeBase[0].title}</h3>
              <p>{knowledgeBase[0].summary}</p>
            </div>
            <dl>
              <div>
                <dt>Owner</dt>
                <dd>{knowledgeBase[0].owner}</dd>
              </div>
              <div>
                <dt>Source</dt>
                <dd>{knowledgeBase[0].source}</dd>
              </div>
              <div>
                <dt>Access</dt>
                <dd>{knowledgeBase[0].access}</dd>
              </div>
            </dl>
            <div class="kb-actions">
              <a href={knowledgeBase[0].url}>Open source</a>
              <a href="#access">Review access</a>
            </div>
          </article>

          <div class="kb-list" aria-label="Knowledge base flow cards">
            {knowledgeBase.map((item) => (
              <article class="kb-card">
                <div class="kb-card-top">
                  <span>{item.source}</span>
                  <em>{item.status}</em>
                </div>
                <strong>{item.title}</strong>
                <p>{item.summary}</p>
                <dl>
                  <div>
                    <dt>Owner</dt>
                    <dd>{item.owner}</dd>
                  </div>
                  <div>
                    <dt>Freshness</dt>
                    <dd>{item.freshness}</dd>
                  </div>
                  <div>
                    <dt>Access</dt>
                    <dd>{item.access}</dd>
                  </div>
                </dl>
                <small>{item.nextAction}</small>
                <div class="kb-tags">
                  {item.tags.map((tag) => <em>{tag}</em>)}
                </div>
                <a class="kb-open" href={item.url}>Open flow</a>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section class="module-panel automation-module" id="automation">
        <div class="module-heading">
          <div>
            <p class="eyebrow">Automation bench</p>
            <h2>Approved run surface</h2>
          </div>
          <span class="module-pill">SPEC-HQ-05 active</span>
        </div>

        <div class="automation-console">
          <article class="automation-status-card">
            <div>
              <p class="eyebrow">Runner contract</p>
              <h3>.123 Playwright pilot is the source of truth</h3>
              <p>The HQ bench now tracks the approved script registry, permission gates, payload requirements, evidence outputs, and dashboard-notification expectations that will move into the wider app.</p>
            </div>
            <dl>
              <div>
                <dt>Latest job</dt>
                <dd>{latestAutomationJob.id}</dd>
              </div>
              <div>
