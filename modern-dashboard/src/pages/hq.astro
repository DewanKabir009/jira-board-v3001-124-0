    repo: "DewanKabir009/jira-board-v3001-124-0",
    summary: "Current CORE QA release board for v3001.124.0 with hosted bridge defaults and the HQ migration path."
  }
];

const knowledgeBase = [
  {
    title: "NY State One Click Cancellation",
    source: "Notion",
    url: "https://zany-seer-d0e.notion.site/NY-STATE-ONE-CLICK-CANCELLATION-3651c22c014480b8b393ef3f40f294f3",
    owner: "CORE QA",
    status: "Live link",
    access: "QA Engineer",
    freshness: "External source",
    summary: "Cancellation compliance flow reference for validating one-click cancellation coverage and expected reservation-state behavior.",
    nextAction: "Open source page and attach structured test cases to this HQ registry.",
    tags: ["Cancellation", "Compliance", "Reservation"]
  },
  {
    title: "Release regression flow registry",
    source: "HQ draft",
    url: "#kb",
    owner: "CORE QA",
    status: "Draft",
    access: "QA Engineer",
    freshness: "Spec pending",
    summary: "Central index for the smoke, regression, and release-signoff flows that should be reused across active release boards.",
    nextAction: "Convert recurring release checklist items into reusable flow records.",
    tags: ["Regression", "Smoke", "Checklist"]
  },
  {
    title: "Jira comment and evidence patterns",
    source: "HQ draft",
    url: "#kb",
    owner: "CORE QA",
    status: "Draft",
    access: "Automation Owner",
    freshness: "Spec pending",
    summary: "Reference patterns for posting Jira-ready findings, evidence links, screenshots, videos, and checklist summaries.",
    nextAction: "Add examples from the Playwright evidence workflow once SPEC-HQ-05 expands.",
    tags: ["Jira", "Evidence", "QA Notes"]
  },
  {
    title: "CORE API health validation",
    source: "HQ draft",
    url: "#kb",
    owner: "Automation Owners",
    status: "Planned",
    access: "Automation Owner",
    freshness: "Automation spec pending",
    summary: "API validation flow library for the service health cards that will run on the five-minute operations cadence.",
    nextAction: "Attach endpoint contracts and expected response rules during SPEC-HQ-06.",
    tags: ["API", "Health", "Operations"]
  }
];

const automationScripts = [
  {
    id: "open-ticket-and-capture",
    name: "Open Jira ticket and capture evidence",
    kind: "Playwright",
    board: "v3001.123.0 pilot",
    environment: "DEV",
    cadence: "On demand",
    status: "Ready on .123",
    permission: "Automation Owner",
    workflow: "run-playwright-job.yml",
    summary: "Opens the selected Jira ticket in the authenticated runner session and captures baseline page evidence.",
    parameters: ["ticketKey", "startUrl"],
    evidence: ["Screenshot", "Video", "Trace", "Logs", "Summary JSON"],
    url: "https://dewankabir009.github.io/jira-board-v3001-123-0/playwright-specs/"
  },
  {
    id: "golfnow-central-smoke",
    name: "GolfNow Central smoke check",
    kind: "Playwright",
    board: "v3001.123.0 pilot",
    environment: "DEV",
    cadence: "On demand",
    status: "Ready on .123",
    permission: "Automation Owner",
    workflow: "run-playwright-job.yml",
    summary: "Runs the approved GolfNow Central smoke path and publishes visual evidence back to the job record.",
    parameters: ["ticketKey", "startUrl"],
    evidence: ["Screenshot", "Video", "Trace", "Logs", "Events"],
    url: "https://dewankabir009.github.io/jira-board-v3001-123-0/playwright-specs/runner-contract.html"
  },
  {
    id: "dashboard-regression-smoke",
    name: "Dashboard regression smoke",
    kind: "Playwright",
    board: "v3001.123.0 pilot",
    environment: "DEV / STG",
    cadence: "After UI changes",
    status: "Ready on .123",
    permission: "Automation Owner",
    workflow: "run-playwright-job.yml",
    summary: "Verifies view toggles, filters, selected ticket panel, Jira links, and evidence modals after dashboard UI changes.",
    parameters: ["ticketKey", "dashboardUrl"],
    evidence: ["Screenshot", "Trace", "Logs", "Summary JSON"],
    url: "https://dewankabir009.github.io/jira-board-v3001-123-0/playwright-specs/dashboard-queue.html"
  },
  {
    id: "core-api-health-probe",
    name: "CORE API health probe",
    kind: "Python API",
    board: "HQ future service",
    environment: "DEV/STG",
    cadence: "Every 5 min",
    status: "Spec planned",
    permission: "Automation Owner",
    workflow: "operations-health.yml planned",
    summary: "Will feed the operations health cards with API availability, latency, and assertion outcomes.",
    parameters: ["environment", "service"],
    evidence: ["JSON response", "Latency", "Assertion log"],
    url: "#status"
  },
  {
    id: "release-checkout-regression",
    name: "Release checkout regression",
    kind: "Playwright",
    board: "HQ future service",
    environment: "STG",
    cadence: "On demand",
    status: "Spec planned",
    permission: "Automation Owner",
    workflow: "run-playwright-job.yml planned",
    summary: "Will run the larger checkout path against release candidates and publish a Jira-ready result summary.",
    parameters: ["ticketKey", "release", "startUrl"],
    evidence: ["Screenshot", "Video", "Trace", "Jira-ready summary"],
    url: "#automation"
  }
];

const latestAutomationJob = {
  id: "core-14440-mpr4ewar-54d72b25",
  status: "Completed",
  ticket: "CORE-14440",
  script: "Open Jira ticket and capture evidence",
  duration: "6.0s",
  sourceBoard: "v3001.123.0",
  resultUrl: "https://dewankabir009.github.io/jira-board-v3001-123-0/playwright-jobs/core-14440-mpr4ewar-54d72b25/",
  actionsUrl: "https://github.com/DewanKabir009/jira-board-v3001-123-0/actions/runs/26648406633"
};

const automationLifecycle = [
  {
    step: "1",
    title: "Validate request",
    detail: "Only approved registry scripts and typed payloads can be dispatched."
  },
  {
    step: "2",
    title: "Run browser or API",
    detail: "Playwright and future Python scripts execute in GitHub Actions or the Cloudflare-backed runner."
  },
  {
    step: "3",
    title: "Publish evidence",
    detail: "Screenshots, videos, traces, logs, events, and summary JSON are written into the job record."
  },
  {
    step: "4",
    title: "Notify dashboard",
    detail: "The dashboard should show ready, failed, and running states without requiring users to open Actions."
  }
];

const automationGuards = [
  "Approved script registry",
  "Role-gated run controls",
  "Typed job payload schema",
  "Failure summaries on dashboard",
  "Screenshot/video modal viewer",
  "GitHub Actions fallback path"
];

const statusCards = [
  { label: "Jira data pull", value: "Healthy", detail: "5 minute single-shot refresh", tone: "green" },
  { label: "Automation runner", value: "Mapped", detail: ".123 pilot contract carried into HQ", tone: "blue" },
  { label: "Cloudflare host", value: "Deployed", detail: "Workers live; workflow token still needed", tone: "green" },
  { label: "Knowledge base", value: "Mapped", detail: "Flow previews and owners drafted", tone: "violet" }
];

const operationsSnapshot = {
  state: "Control surface drafted",
  cadence: "5 minute probe contract",
  source: "SPEC-HQ-06",
  updated: "Live cards use known board and workflow signals until the central API monitor is connected.",
  summary: "The HQ operations panel separates current hosted health from planned service probes, so QA can see data freshness, deploy status, bridge auth, and automation evidence readiness from one place."
};

const operationsServices = [
  {
    name: "Jira data pull",
    state: "Healthy",
    tone: "healthy",
    cadence: "Every 5 minutes and on demand",
    source: "refresh-jira-board.yml",
    signal: "dashboard-data.json published with latest pull timestamp",
    next: "Keep current board freshness visible in the HQ status panel."
  },
  {
    name: "GitHub Pages deployment",
    state: "Healthy",
    tone: "healthy",
    cadence: "On every publish",
    source: "pages-build-deployment",
    signal: ".124 and .123 HQ mirrors render from generated Astro output",
    next: "Continue using Pages as fallback while Cloudflare custom-domain and workflow deploy paths are hardened."
  },
  {
    name: "Jira write bridge",
    state: "Auth gated",
    tone: "auth",
    cadence: "On demand",
    source: "Cloudflare Worker",
    signal: "Assign, checklist, and comment routes require Access login before writes",
    next: "Surface the login path and route status before user actions."
  },
  {
    name: "Playwright evidence publishing",
    state: "Healthy",
    tone: "healthy",
    cadence: "On demand",
    source: "v3001.123.0 run-playwright-job.yml",
    signal: "Summary JSON, screenshot, video, trace, logs, and events are stored per job",
    next: "Move the pilot runner into the HQ-owned automation registry."
  },
  {
    name: "CORE API health probe",
    state: "Planned",
    tone: "planned",
    cadence: "Every 5 minutes",
    source: "operations-health.yml planned",
    signal: "Status code, latency, assertion log, and service tag per endpoint",
    next: "Add Python/API probes after service endpoints and credentials are approved."
  },
  {
    name: "Slack notification pipeline",
    state: "Planned",
    tone: "planned",
    cadence: "On failure and assignment change",
    source: "Workflow or Worker notifier",
    signal: "Delivery state, channel, assignee mention, and failure summary",
    next: "Connect automation and data-pull failures to dashboard-visible alerts first."
  }
];

const operationsCadence = [
  { label: "Collect", value: "5 min", detail: "API probes and board freshness checks create a compact JSON status record." },
  { label: "Publish", value: "Pages", detail: "The latest status artifact is published beside the active release dashboard." },
  { label: "Notify", value: "Inline", detail: "Failed runs and stale pulls appear in the dashboard before users need Actions." },
  { label: "Escalate", value: "Slack", detail: "Future notifier routes critical failures to the right QA channel and assignee." }
];

const operationsSignals = [
  { label: "Availability", detail: "Pass/fail per service plus auth-gated state." },
  { label: "Latency", detail: "Endpoint response timing for future API probes." },
  { label: "Freshness", detail: "Last successful data pull, publish, and automation evidence timestamp." },
  { label: "Evidence", detail: "Logs, screenshots, videos, traces, and summary JSON links." }
];

const accessRoles = [
  {
    role: "QA Admin",
    people: "CORE QA leads",
    access: "All boards, admin console, automation approvals, AI settings",
    state: "Planned backend"
  },
  {
    role: "Automation Owner",
    people: "Approved automation maintainers",
    access: "Run Playwright/Python scripts, review evidence, edit runbook metadata",
    state: "Ready to gate"
  },
  {
    role: "QA Engineer",
    people: "CORE QA contributors",
    access: "View boards, knowledge base, ticket detail, evidence, operations health",
    state: "Default target"
  },
  {
    role: "Stakeholder Viewer",
    people: "Product, dev leads, support partners",
    access: "Read-only board, AI summary, status overview, selected knowledge pages",
    state: "Read-only"
  }
];

const guardedModules = [
  {
    name: "Automation approvals",
    required: "Automation Owner",
    status: "Restricted",
    detail: "Users can view available scripts, but execution controls stay gated until approval."
  },
  {
    name: "Admin console",
    required: "QA Admin",
    status: "Locked",
    detail: "User and section permission management stays hidden behind a request-access pattern."
  },
  {
    name: "AI summary settings",
    required: "QA Admin",
    status: "Planned",
    detail: "Prompt controls and source selection will be admin-only once the AI endpoint exists."
  },
  {
    name: "Knowledge base",
    required: "QA Engineer",
    status: "Visible",
    detail: "Core test flow links remain broadly visible while sensitive pages can be marked restricted."
  }
];

const hqSpecs = [
  { id: "SPEC-HQ-00", title: "Product shell", status: "Implemented", detail: "HQ navigation, workbench layout, module cards." },
  { id: "SPEC-HQ-01", title: "Board registry", status: "Implemented", detail: ".122, .123, .124 board slots and preview panel." },
  { id: "SPEC-HQ-02", title: "Cloudflare hosting", status: "In progress", detail: "Cloudflare Workers are deployed; GitHub workflow deploy waits on CLOUDFLARE_API_TOKEN." },
  { id: "SPEC-HQ-03", title: "Auth and permissions", status: "In progress", detail: "Role model, gated cards, and request-access UI are drafted." },
  { id: "SPEC-HQ-04", title: "Knowledge base", status: "In progress", detail: "Flow cards, source links, ownership, and freshness are drafted." },
  { id: "SPEC-HQ-05", title: "Automation bench", status: "In progress", detail: "Playwright pilot registry, lifecycle, evidence, and runner guards are drafted." },
  { id: "SPEC-HQ-06", title: "Operational status", status: "In progress", detail: "Service health cards, probe cadence, and status publishing contract are drafted." },
  { id: "SPEC-HQ-07", title: "AI release summary", status: "Planned", detail: "Ticket risk, stale work, QA recommendations." },
  { id: "SPEC-HQ-08", title: "Admin console", status: "Planned", detail: "Users, roles, sections, and script permissions." }
];
---

<QaHqLayout title="CORE QA Headquarters">
  <main class="hq-shell" id="hq-main">
    <aside class="hq-sidebar" aria-label="CORE QA headquarters navigation">
      <div class="hq-brand">
        <span class="brand-mark" aria-hidden="true">QA</span>
        <div>
          <p class="eyebrow">CORE</p>
          <h1>QA Headquarters</h1>
        </div>
      </div>

      <nav class="hq-nav" aria-label="HQ modules">
        <a class="active" href="#boards">Release boards</a>
        <a href="#kb">Knowledge base</a>
        <a href="#automation">Automation bench</a>
        <a href="#ai">AI summary</a>
        <a href="#status">Operations status</a>
        <a href="#access">Access control</a>
      </nav>

      <div class="side-status">
        <p class="eyebrow">Current pilot</p>
        <strong>v3001.124.0</strong>
        <span>Cloudflare migration target</span>
      </div>
    </aside>

    <section class="hq-workbench" aria-label="CORE QA HQ workbench">
      <header class="command-strip">
        <div>
          <p class="eyebrow">Test bench</p>
          <h2>CORE QA operating hub</h2>
          <p class="command-summary">Central workspace for release dashboards, test knowledge, automation evidence, AI triage, and service health.</p>
        </div>
        <div class="command-actions" aria-label="HQ quick links">
          <a href="#boards">Boards</a>
          <a href="#automation">Runbook</a>
          <a href="#specs">Specs</a>
        </div>
      </header>

      <section class="status-grid" aria-label="Operational status snapshot">
        {statusCards.map((card) => (
          <article class={`status-card ${card.tone}`}>
            <span>{card.label}</span>
            <strong>{card.value}</strong>
            <p>{card.detail}</p>
          </article>
        ))}
      </section>

      <section class="module-panel board-module" id="boards">
        <div class="module-heading">
          <div>
            <p class="eyebrow">Release boards</p>
            <h2>Dashboard command center</h2>
          </div>
          <span class="module-pill">3 releases tracked</span>
        </div>

        <div class="board-tabs" role="list" aria-label="Release dashboard shortcuts">
          {releaseBoards.map((board) => (
            <a class={board.status === "Current" ? "board-tab current" : "board-tab"} href={board.modernUrl}>
              <span>{board.label}</span>
              <strong>{board.release}</strong>
              <em>{board.status}</em>
            </a>
          ))}
        </div>

        <div class="board-grid">
          {releaseBoards.map((board) => (
            <article class={board.status === "Current" ? "board-card current" : "board-card"}>
              <div class="board-card-top">
                <div>
                  <p class="eyebrow">{board.state}</p>
                  <h3>{board.release}</h3>
                </div>
                <span>{board.status}</span>
              </div>
              <p>{board.summary}</p>
              <dl>
                <div>
                  <dt>Repository</dt>
                  <dd>{board.repo}</dd>
                </div>
              </dl>
              <div class="card-actions">
                <a href={board.modernUrl}>Modern board</a>
                <a href={board.url}>Legacy board</a>
              </div>
            </article>
          ))}
        </div>

        <article class="board-preview">
          <div class="preview-heading">
            <div>
              <p class="eyebrow">Current preview</p>
              <h3>v3001.124.0 modern dashboard</h3>
            </div>
            <a href="https://dewankabir009.github.io/jira-board-v3001-124-0/modern/">Open full board</a>
          </div>
          <iframe title="v3001.124.0 modern board preview" src="https://dewankabir009.github.io/jira-board-v3001-124-0/modern/" loading="lazy"></iframe>
        </article>
      </section>

      <section class="module-panel kb-module" id="kb">
        <div class="module-heading">
          <div>
            <p class="eyebrow">Knowledge base</p>
            <h2>Test flow library</h2>
          </div>
          <span class="module-pill">SPEC-HQ-04 active</span>
        </div>

        <div class="kb-console">
          <article class="kb-spotlight">
            <div>
              <p class="eyebrow">Featured flow</p>
              <h3>{knowledgeBase[0].title}</h3>
              <p>{knowledgeBase[0].summary}</p>
            </div>
            <dl>
              <div>
                <dt>Owner</dt>
                <dd>{knowledgeBase[0].owner}</dd>
              </div>
              <div>
                <dt>Source</dt>
                <dd>{knowledgeBase[0].source}</dd>
              </div>
              <div>
                <dt>Access</dt>
                <dd>{knowledgeBase[0].access}</dd>
              </div>
            </dl>
            <div class="kb-actions">
              <a href={knowledgeBase[0].url}>Open source</a>
              <a href="#access">Review access</a>
            </div>
          </article>

          <div class="kb-list" aria-label="Knowledge base flow cards">
            {knowledgeBase.map((item) => (
              <article class="kb-card">
                <div class="kb-card-top">
                  <span>{item.source}</span>
                  <em>{item.status}</em>
                </div>
                <strong>{item.title}</strong>
                <p>{item.summary}</p>
                <dl>
                  <div>
                    <dt>Owner</dt>
                    <dd>{item.owner}</dd>
                  </div>
                  <div>
                    <dt>Freshness</dt>
                    <dd>{item.freshness}</dd>
                  </div>
                  <div>
                    <dt>Access</dt>
                    <dd>{item.access}</dd>
                  </div>
                </dl>
                <small>{item.nextAction}</small>
                <div class="kb-tags">
                  {item.tags.map((tag) => <em>{tag}</em>)}
                </div>
                <a class="kb-open" href={item.url}>Open flow</a>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section class="module-panel automation-module" id="automation">
        <div class="module-heading">
          <div>
            <p class="eyebrow">Automation bench</p>
            <h2>Approved run surface</h2>
          </div>
          <span class="module-pill">SPEC-HQ-05 active</span>
        </div>

        <div class="automation-console">
          <article class="automation-status-card">
            <div>
              <p class="eyebrow">Runner contract</p>
              <h3>.123 Playwright pilot is the source of truth</h3>
              <p>The HQ bench now tracks the approved script registry, permission gates, payload requirements, evidence outputs, and dashboard-notification expectations that will move into the wider app.</p>
            </div>
            <dl>
              <div>
                <dt>Latest job</dt>
                <dd>{latestAutomationJob.id}</dd>
              </div>
              <div>
                <dt>Status</dt>
                <dd>{latestAutomationJob.status}</dd>
              </div>
              <div>
                <dt>Duration</dt>
                <dd>{latestAutomationJob.duration}</dd>
              </div>
              <div>
                <dt>Source board</dt>
                <dd>{latestAutomationJob.sourceBoard}</dd>
              </div>
            </dl>
            <div class="automation-actions">
              <a href={latestAutomationJob.resultUrl}>View latest results</a>
              <a href={latestAutomationJob.actionsUrl}>Actions run</a>
            </div>
          </article>

          <div class="automation-lifecycle" aria-label="Automation run lifecycle">
            {automationLifecycle.map((item) => (
              <article>
                <span>{item.step}</span>
                <strong>{item.title}</strong>
                <p>{item.detail}</p>
              </article>
            ))}
          </div>

          <div class="script-list" aria-label="Approved and planned automation scripts">
            {automationScripts.map((script) => (
              <article class={script.status.includes("Ready") ? "script-card ready" : "script-card"}>
                <div class="script-card-top">
                  <div>
                    <span>{script.id}</span>
                    <strong>{script.name}</strong>
                  </div>
                  <em>{script.status}</em>
                </div>
                <p>{script.summary}</p>
                <dl>
                  <div>
                    <dt>Kind</dt>
                    <dd>{script.kind}</dd>
                  </div>
                  <div>
                    <dt>Board</dt>
                    <dd>{script.board}</dd>
                  </div>
                  <div>
                    <dt>Environment</dt>
                    <dd>{script.environment}</dd>
                  </div>
                  <div>
                    <dt>Cadence</dt>
                    <dd>{script.cadence}</dd>
                  </div>
                  <div>
                    <dt>Permission</dt>
                    <dd>{script.permission}</dd>
                  </div>
                  <div>
                    <dt>Workflow</dt>
                    <dd>{script.workflow}</dd>
                  </div>
                </dl>
                <div class="script-tags" aria-label={`${script.name} required parameters`}>
                  {script.parameters.map((parameter) => <span>{parameter}</span>)}
                </div>
                <div class="evidence-tags" aria-label={`${script.name} evidence outputs`}>
                  {script.evidence.map((artifact) => <em>{artifact}</em>)}
                </div>
                <a class="script-open" href={script.url}>Open runbook</a>
              </article>
            ))}
          </div>

          <article class="automation-guard-card">
            <div>
              <p class="eyebrow">Production gates</p>
              <h3>What must stay true before this becomes a shared HQ runner</h3>
            </div>
            <ul>
              {automationGuards.map((guard) => <li>{guard}</li>)}
            </ul>
          </article>
        </div>
      </section>

      <section class="module-panel operations-module" id="status">
        <div class="module-heading">
          <div>
            <p class="eyebrow">Operations status</p>
            <h2>Service health command panel</h2>
          </div>
          <span class="module-pill">SPEC-HQ-06 active</span>
        </div>

        <div class="operations-console">
          <article class="operations-hero">
            <div>
              <p class="eyebrow">{operationsSnapshot.source}</p>
              <h3>{operationsSnapshot.state}</h3>
              <p>{operationsSnapshot.summary}</p>
            </div>
            <dl>
              <div>
                <dt>Cadence</dt>
                <dd>{operationsSnapshot.cadence}</dd>
              </div>
              <div>
                <dt>Source</dt>
                <dd>{operationsSnapshot.source}</dd>
              </div>
              <div>
                <dt>Current note</dt>
                <dd>{operationsSnapshot.updated}</dd>
              </div>
            </dl>
          </article>

          <div class="ops-service-grid" aria-label="Tracked service health">
            {operationsServices.map((service) => (
              <article class={`ops-service-card ${service.tone}`}>
                <div class="ops-service-top">
                  <strong>{service.name}</strong>
                  <span class={`ops-state ${service.tone}`}>{service.state}</span>
                </div>
                <dl>
                  <div>
                    <dt>Cadence</dt>
                    <dd>{service.cadence}</dd>
                  </div>
                  <div>
                    <dt>Source</dt>
                    <dd>{service.source}</dd>
                  </div>
                  <div>
                    <dt>Signal</dt>
                    <dd>{service.signal}</dd>
                  </div>
                </dl>
                <p>{service.next}</p>
              </article>
            ))}
          </div>

          <div class="ops-cadence-grid" aria-label="Operational status lifecycle">
            {operationsCadence.map((item) => (
              <article>
                <span>{item.label}</span>
                <strong>{item.value}</strong>
                <p>{item.detail}</p>
              </article>
            ))}
          </div>

          <article class="ops-signals-card">
            <div>
              <p class="eyebrow">Monitoring contract</p>
              <h3>What the five-minute health artifact should contain</h3>
            </div>
            <div class="ops-signal-grid">
              {operationsSignals.map((signal) => (
                <div>
                  <strong>{signal.label}</strong>
                  <p>{signal.detail}</p>
                </div>
              ))}
            </div>
          </article>
        </div>
      </section>

      <section class="module-grid">
        <article class="module-panel ai-panel" id="ai">
          <div class="module-heading">
            <div>
              <p class="eyebrow">AI summary</p>
              <h2>Release intelligence</h2>
            </div>
            <span class="module-pill locked">Worker API planned</span>
          </div>
          <div class="ai-summary-card">
            <strong>Current active board summary</strong>
            <p>Future AI pass will summarize ticket risk, stale work, component concentration, latest comments, media evidence, and recommended QA focus for the selected release.</p>
            <ul>
              <li>Summarize ticket intent and risk.</li>
              <li>Suggest next QA steps and missing checklist items.</li>
              <li>Draft Jira-ready test notes from evidence.</li>
            </ul>
          </div>
        </article>

        <article class="module-panel access-panel" id="access">
          <div class="module-heading">
            <div>
              <p class="eyebrow">Access control</p>
              <h2>Permission-aware sections</h2>
            </div>
            <span class="module-pill locked">SPEC-HQ-03 active</span>
          </div>
          <div class="access-console">
            <div class="identity-card">
              <p class="eyebrow">Signed-in context</p>
              <strong>Cloudflare Access pending</strong>
              <span>Static preview mode uses the planned QA Engineer baseline until Access headers and RBAC storage are connected.</span>
            </div>

            <div class="role-matrix" aria-label="Planned HQ roles and permissions">
              {accessRoles.map((item) => (
                <article class="role-card">
                  <div>
                    <strong>{item.role}</strong>
                    <span>{item.state}</span>
                  </div>
                  <p>{item.people}</p>
                  <small>{item.access}</small>
                </article>
              ))}
            </div>

            <div class="guarded-grid" aria-label="Protected HQ module states">
              {guardedModules.map((module) => (
                <article class={module.status === "Visible" ? "guarded-card visible" : "guarded-card"}>
                  <div>
                    <strong>{module.name}</strong>
                    <span>{module.status}</span>
                  </div>
                  <p>{module.detail}</p>
                  <small>Required role: {module.required}</small>
                </article>
              ))}
            </div>

            <div class="locked-preview">
              <div class="blurred-content" aria-hidden="true">
                <span></span>
                <span></span>
                <span></span>
              </div>
              <div class="access-callout">
                <strong>Need access?</strong>
                <p>Restricted HQ modules will keep the content shape visible, blur the protected details, and route the user to an access request instead of a dead screen.</p>
                <div class="access-actions">
                  <a href="mailto:dewan.kabir@versantmedia.com?subject=CORE%20QA%20HQ%20access%20request">Request access</a>
                  <a href="/jira-board-v3001-124-0/modern/hq/#specs">Open spec status</a>
                </div>
              </div>
            </div>
          </div>
        </article>
      </section>

      <section class="module-panel specs-panel" id="specs">
        <div class="module-heading">
          <div>
            <p class="eyebrow">Spec-driven delivery</p>
            <h2>HQ build checklist</h2>
          </div>
          <span class="module-pill">2 complete / 5 active</span>
        </div>
        <div class="spec-grid">
          {hqSpecs.map((spec) => (
            <article class={spec.status === "Implemented" ? "spec-card done" : spec.status === "In progress" ? "spec-card active" : "spec-card"}>
              <span>{spec.id}</span>
              <strong>{spec.title}</strong>
              <em>{spec.status}</em>
              <p>{spec.detail}</p>
            </article>
          ))}
        </div>
      </section>
    </section>
  </main>
</QaHqLayout>
