  <script is:inline>
    (() => {
      const runner = document.querySelector(".ai-runner-card");
      const generateButton = document.querySelector("#hq-ai-generate");
      const copyButton = document.querySelector("#hq-ai-copy");
      const statusLine = document.querySelector("#hq-ai-status");
      const resultCard = document.querySelector("#hq-ai-result");
      const resultTitle = document.querySelector("#hq-ai-result-title");
      const resultMeta = document.querySelector("#hq-ai-result-meta");
      const resultSource = document.querySelector("#hq-ai-result-source");
      const resultSummary = document.querySelector("#hq-ai-result-summary");
      const riskList = document.querySelector("#hq-ai-risks");
      const focusList = document.querySelector("#hq-ai-focus");
      const ticketList = document.querySelector("#hq-ai-tickets");
      const gateList = document.querySelector("#hq-ai-gates");
      const riskTitle = document.querySelector("#hq-ai-risks-title");
      const focusTitle = document.querySelector("#hq-ai-focus-title");
      const ticketTitle = document.querySelector("#hq-ai-tickets-title");
      const gateTitle = document.querySelector("#hq-ai-gates-title");
      const promptTemplate = document.querySelector("#hq-ai-prompt-template");
      const promptInput = document.querySelector("#hq-ai-prompt");
      let latestBriefText = "";
      const promptPresets = {
        free_form: "Ask anything about the current release board. Example: Which tickets look riskiest for QA and why?",
        ticket_lookup: "What tickets are assigned to Dewan? List ticket key, summary, status, priority, type, and parent if applicable.",
        release_triage: "Summarize the current v3001.124.0 board for QA. Call out the biggest risks, tickets to watch, testing focus, and review gates before anyone posts Jira or Slack updates.",
        qa_focus: "Create a QA focus plan for the current release. Prioritize P0/P1 work, parent tickets with subtasks, stale evidence, components with concentration, and what should be tested next.",
        jira_notes: "Draft Jira-ready QA notes for the current release. Keep the notes safe for review, cite ticket keys from the board data, and separate findings, concerns, evidence gaps, and next actions.",
        leadership: "Create a concise leadership rollup for the current release. Include release health, top risks, ownership pressure, evidence gaps, and what needs review before status is shared."
      };

      if (!runner || !generateButton || !statusLine || !resultCard) {
        return;
      }

      if (promptTemplate && promptInput) {
        promptTemplate.addEventListener("change", () => {
          const nextPrompt = promptPresets[promptTemplate.value];
          if (nextPrompt) {
            promptInput.value = nextPrompt;
          }
        });
      }

      generateButton.addEventListener("click", async () => {
        const userPrompt = promptInput?.value?.trim() || promptPresets.release_triage;
        generateButton.disabled = true;
        if (copyButton) copyButton.disabled = true;
        statusLine.textContent = "Generating draft with Cloudflare Workers AI...";
        runner.classList.add("is-loading");
        runner.classList.remove("has-error");

        try {
          const response = await fetch(runner.dataset.aiEndpoint, {
            method: "POST",
            headers: { "content-type": "application/json" },
            body: JSON.stringify({
              release: runner.dataset.aiRelease,
              output: "release_brief",
              promptTemplate: promptTemplate?.value || "release_triage",
              userPrompt
            })
          });
          const payload = await response.json();

          if (!response.ok || !payload.ok) {
            throw new Error(payload.message || `AI request failed with HTTP ${response.status}`);
          }

          renderBrief(payload);
          statusLine.textContent = payload.warning
            ? "Draft ready with deterministic fallback."
            : payload.answerType === "ticket_test_plan"
              ? "AI ticket test plan ready for review."
            : payload.answerType === "free_form"
              ? "AI free-form analysis ready for review."
            : payload.answerType === "assignee_lookup" || payload.answerType === "component_lookup" || payload.answerType === "ticket_lookup" || payload.answerType === "direct_lookup"
              ? "AI analysis ready from exact board lookup."
            : "AI draft ready for review from your prompt.";
          runner.classList.remove("has-error");
        } catch (error) {
          statusLine.textContent = `AI endpoint unavailable: ${error.message}. Open the Cloudflare HQ URL, not GitHub Pages, for live AI.`;
          runner.classList.add("has-error");
        } finally {
          runner.classList.remove("is-loading");
          generateButton.disabled = false;
        }
      });

      if (copyButton) {
        copyButton.addEventListener("click", async () => {
          if (!latestBriefText) return;

          try {
            await navigator.clipboard.writeText(latestBriefText);
            statusLine.textContent = "AI brief copied.";
          } catch {
            statusLine.textContent = "Copy failed. Select the brief text manually.";
          }
        });
      }

      function renderBrief(payload) {
        const brief = payload.brief || {};
        const source = payload.source || {};
        const answerType = payload.answerType || brief.answerType || "release_brief";
        resultCard.hidden = false;
        setResultLabels(answerType);
        resultTitle.textContent = brief.title || "Draft release brief";
        resultMeta.textContent = `${payload.provider || "Cloudflare Workers AI"} / ${payload.model || "unknown model"}`;
        resultSource.textContent = `${payload.release || "release"} / pulled ${source.pulledAtDisplay || source.pulledAt || "unknown"}`;
        resultSummary.textContent = brief.summary || "";
        renderList(riskList, brief.topRisks);
        renderList(focusList, brief.qaFocus);
        renderTicketList(ticketList, brief.ticketsToWatch || []);
        renderList(gateList, brief.reviewGates);
        latestBriefText = buildBriefText(payload);
        if (copyButton) copyButton.disabled = !latestBriefText;
      }

      function setResultLabels(answerType) {
        const lookupMode = answerType === "assignee_lookup" || answerType === "component_lookup" || answerType === "ticket_lookup" || answerType === "direct_lookup";
        const testPlanMode = answerType === "ticket_test_plan";
        const freeFormMode = answerType === "free_form";

        if (riskTitle) riskTitle.textContent = testPlanMode ? "Coverage risks" : lookupMode ? "AI lookup insights" : freeFormMode ? "Key findings" : "Top risks";
        if (focusTitle) focusTitle.textContent = testPlanMode ? "Test scenarios" : lookupMode ? "Matched ticket analysis" : freeFormMode ? "Answer details" : "QA focus";
        if (ticketTitle) ticketTitle.textContent = testPlanMode ? "Related tickets" : lookupMode ? "Ticket links" : freeFormMode ? "Relevant tickets" : "Tickets to watch";
        if (gateTitle) gateTitle.textContent = "Review gates";
      }

      function renderList(list, items) {
        if (!list) return;
        list.textContent = "";
        const cleanItems = Array.isArray(items) && items.length ? items : ["No items returned."];

        cleanItems.forEach((item) => {
          const li = document.createElement("li");
          li.textContent = item;
          list.appendChild(li);
        });
      }

      function renderTicketList(list, tickets) {
        if (!list) return;
        list.textContent = "";
        const cleanTickets = Array.isArray(tickets) && tickets.length ? tickets : [];

        if (!cleanTickets.length) {
          const li = document.createElement("li");
          li.textContent = "No tickets returned.";
          list.appendChild(li);
          return;
        }

        cleanTickets.forEach((ticket) => {
          const li = document.createElement("li");
          li.className = "ai-ticket-item";
          const title = document.createElement(ticket.url ? "a" : "strong");
          title.textContent = ticket.key || "Unknown";

          if (ticket.url) {
            title.href = ticket.url;
            title.target = "_blank";
            title.rel = "noopener";
          }

          const detail = document.createElement("span");
          const summary = ticket.summary ? ` - ${ticket.summary}` : "";
          const metadata = [
            ticket.type,
            ticket.status,
            ticket.priority,
            ticket.assignee ? `Assignee: ${ticket.assignee}` : "",
            ticket.assignedDeveloper ? `Dev: ${ticket.assignedDeveloper}` : "",
            Array.isArray(ticket.components) && ticket.components.length ? `Components: ${ticket.components.join(", ")}` : "",
            ticket.parent ? `Parent: ${ticket.parent}` : ""
          ].filter(Boolean).join(" | ");
          detail.textContent = `${summary}${metadata ? ` (${metadata})` : ""}${ticket.reason ? ` - ${ticket.reason}` : ""}`;
          li.append(title, detail);
          list.appendChild(li);
        });
      }

      function buildBriefText(payload) {
        const brief = payload.brief || {};
        const answerType = payload.answerType || brief.answerType || "release_brief";
        const lookupMode = answerType === "assignee_lookup" || answerType === "component_lookup" || answerType === "ticket_lookup" || answerType === "direct_lookup";
        const testPlanMode = answerType === "ticket_test_plan";
        const freeFormMode = answerType === "free_form";
        const tickets = (brief.ticketsToWatch || []).map(formatTicketForCopy).join("\n");
        return [
          brief.title || "Draft release brief",
          "",
          brief.summary || "",
          "",
          testPlanMode ? "Coverage risks:" : lookupMode ? "AI lookup insights:" : freeFormMode ? "Key findings:" : "Top risks:",
          toBulletList(brief.topRisks),
          "",
          testPlanMode ? "Test scenarios:" : lookupMode ? "Matched ticket analysis:" : freeFormMode ? "Answer details:" : "QA focus:",
          toBulletList(brief.qaFocus),
          "",
          testPlanMode ? "Related tickets:" : lookupMode ? "Ticket links:" : freeFormMode ? "Relevant tickets:" : "Tickets to watch:",
          tickets || "- No tickets returned.",
          "",
          "Review gates:",
          toBulletList(brief.reviewGates),
          "",
          `Source: ${payload.release || "release"} / ${payload.source?.pulledAtDisplay || payload.source?.pulledAt || "unknown pull"}`
        ].join("\n");
      }

      function toBulletList(items) {
        return Array.isArray(items) && items.length ? items.map((item) => `- ${item}`).join("\n") : "- No items returned.";
      }

      function formatTicketForCopy(ticket) {
        const key = ticket.key || "Unknown";
        const title = ticket.url ? `[${key}](${ticket.url})` : key;
        const summary = ticket.summary ? ` - ${ticket.summary}` : "";
        const metadata = [
          ticket.type,
          ticket.status,
          ticket.priority,
          ticket.assignee ? `Assignee: ${ticket.assignee}` : "",
          ticket.assignedDeveloper ? `Dev: ${ticket.assignedDeveloper}` : "",
          Array.isArray(ticket.components) && ticket.components.length ? `Components: ${ticket.components.join(", ")}` : "",
          ticket.parent ? `Parent: ${ticket.parent}` : ""
        ].filter(Boolean).join(" | ");
        return `- ${title}${summary}${metadata ? ` (${metadata})` : ""}${ticket.reason ? ` - ${ticket.reason}` : ""}`;
      }
    })();
  </script>
</QaHqLayout>
