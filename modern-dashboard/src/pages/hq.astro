---
import QaHqLayout from "../layouts/QaHqLayout.astro";
import "../styles/qa-hq.css";

const releaseBoards = [
  {
    release: "v3001.122.0",
    label: ".122",
    status: "Active",
    state: "Live",
    url: "https://dewankabir009.github.io/jira-board-v3001-122-0/",
