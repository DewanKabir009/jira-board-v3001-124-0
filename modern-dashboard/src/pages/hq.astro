              <span>{spec.id}</span>
              <strong>{spec.title}</strong>
              <em>{spec.status}</em>
              <p>{spec.detail}</p>
            </article>
          ))}
        </div>
      </section>
    </section>
  </main>

  <script is:inline>
    (() => {
      const runner = document.querySelector(".ai-runner-card");
      const generateButton = document.querySelector("#hq-ai-generate");
      const copyButton = document.querySelector("#hq-ai-copy");
      const statusLine = document.querySelector("#hq-ai-status");
      const resultCard = document.querySelector("#hq-ai-result");
      const resultTitle = document.querySelector("#hq-ai-result-title");
      const resultMeta = document.querySelector("#hq-ai-result-meta");
      const resultSource = document.querySelector("#hq-ai-result-source");
      const resultSummary = document.querySelector("#hq-ai-result-summary");
      const riskList = document.querySelector("#hq-ai-risks");
      const focusList = document.querySelector("#hq-ai-focus");
      const ticketList = document.querySelector("#hq-ai-tickets");
      const gateList = document.querySelector("#hq-ai-gates");
      const riskTitle = document.querySelector("#hq-ai-risks-title");
      const focusTitle = document.querySelector("#hq-ai-focus-title");
      const ticketTitle = document.querySelector("#hq-ai-tickets-title");
      const gateTitle = document.querySelector("#hq-ai-gates-title");
      const documentsPanel = document.querySelector("#hq-ai-documents");
      const promptTemplate = document.querySelector("#hq-ai-prompt-template");
      const promptInput = document.querySelector("#hq-ai-prompt");
      const chatCard = document.querySelector(".ai-chat-card");
      const chatLog = document.querySelector("#hq-ai-chat-log");
      const chatForm = document.querySelector("#hq-ai-chat-form");
      const chatInput = document.querySelector("#hq-ai-chat-input");
      const chatSend = document.querySelector("#hq-ai-chat-send");
      const chatStatus = document.querySelector("#hq-ai-chat-status");
      const chatPromptButtons = Array.from(document.querySelectorAll("[data-ai-chat-prompt]"));
      let latestBriefText = "";
      const chatHistory = [];
      const promptPresets = {
        free_form: "Ask anything about the current release board. Example: Which tickets look riskiest for QA and why?",
        ticket_lookup: "What tickets are assigned to Dewan? List ticket key, summary, status, priority, type, and parent if applicable.",
        release_triage: "Summarize the current v3001.124.0 board for QA. Call out the biggest risks, tickets to watch, testing focus, and review gates before anyone posts Jira or Slack updates.",
        qa_focus: "Create a QA focus plan for the current release. Prioritize P0/P1 work, parent tickets with subtasks, stale evidence, components with concentration, and what should be tested next.",
        jira_notes: "Draft Jira-ready QA notes for the current release. Keep the notes safe for review, cite ticket keys from the board data, and separate findings, concerns, evidence gaps, and next actions.",
        leadership: "Create a concise leadership rollup for the current release. Include release health, top risks, ownership pressure, evidence gaps, and what needs review before status is shared."
      };

      if (!runner || !generateButton || !statusLine || !resultCard) {
        return;
      }

      if (promptTemplate && promptInput) {
        promptTemplate.addEventListener("change", () => {
          const nextPrompt = promptPresets[promptTemplate.value];
          if (nextPrompt) {
            promptInput.value = nextPrompt;
          }
        });
      }

      initChatAgent();

      generateButton.addEventListener("click", async () => {
        const userPrompt = promptInput?.value?.trim() || promptPresets.release_triage;
        generateButton.disabled = true;
        if (copyButton) copyButton.disabled = true;
        statusLine.textContent = "Generating draft with Cloudflare Workers AI...";
        runner.classList.add("is-loading");
        runner.classList.remove("has-error");

        try {
          const response = await fetch(runner.dataset.aiEndpoint, {
            method: "POST",
            headers: { "content-type": "application/json" },
            body: JSON.stringify({
              release: runner.dataset.aiRelease,
              output: "release_brief",
              promptTemplate: promptTemplate?.value || "release_triage",
              userPrompt
            })
          });
          const payload = await response.json();

          if (!response.ok || !payload.ok) {
            throw new Error(payload.message || `AI request failed with HTTP ${response.status}`);
          }

          renderBrief(payload);
          statusLine.textContent = payload.warning
            ? "Draft ready with deterministic fallback."
            : payload.answerType === "ticket_test_plan"
              ? "AI ticket test plan ready for review."
            : payload.answerType === "main_ticket_rundown"
              ? "Leadership-ready main ticket rundown ready to copy."
            : payload.answerType === "free_form"
              ? "AI free-form analysis ready for review."
            : payload.answerType === "assignee_lookup" || payload.answerType === "comment_file_lookup" || payload.answerType === "component_lookup" || payload.answerType === "priority_lookup" || payload.answerType === "ticket_lookup" || payload.answerType === "direct_lookup"
              ? "AI analysis ready from exact board lookup."
            : "AI draft ready for review from your prompt.";
          runner.classList.remove("has-error");
        } catch (error) {
          statusLine.textContent = `AI endpoint unavailable: ${error.message}. Open the Cloudflare HQ URL, not GitHub Pages, for live AI.`;
          runner.classList.add("has-error");
        } finally {
          runner.classList.remove("is-loading");
          generateButton.disabled = false;
        }
      });

      if (copyButton) {
        copyButton.addEventListener("click", async () => {
          if (!latestBriefText) return;

          try {
            await navigator.clipboard.writeText(latestBriefText);
            statusLine.textContent = "AI brief copied.";
          } catch {
            statusLine.textContent = "Copy failed. Select the brief text manually.";
          }
        });
      }

      function initChatAgent() {
        if (!chatCard || !chatLog || !chatForm || !chatInput || !chatSend || !chatStatus) {
          return;
        }

        appendChatMessage("assistant", {
          answer: "Hi, I am the CORE QA HQ assistant. I can turn the current release and Sprint 2026.8 board data into readable answers, ticket tables, and copy-ready leadership notes.",
          highlights: [
            "Use sprint or 2026.8 when you want backlog scope.",
            "Ask for a ticket key, assignee, priority, status, or component when you want an exact linked table.",
            "Exact matches are filtered from dashboard-data.json before AI turns them into a readable answer."
          ],
          tickets: [],
          sprint: null,
          followUps: [
            "How many P0 tickets are in the current release?",
            "Summarize Sprint 2026.8 by status.",
            "Which tickets are assigned to Dewan?"
          ],
          sourceNotes: ["Ready. No AI request has been sent yet."]
        }, { recordHistory: false, intro: true });

        chatPromptButtons.forEach((button) => {
          button.addEventListener("click", () => {
            chatInput.value = button.getAttribute("data-ai-chat-prompt") || "";
            chatInput.focus();
          });
        });

        chatForm.addEventListener("submit", async (event) => {
          event.preventDefault();
          const message = chatInput.value.trim();

          if (!message) {
            chatStatus.textContent = "Type a ticket or sprint question first.";
            return;
          }

          appendChatMessage("user", message);
          chatInput.value = "";
          setChatBusy(true, "Thinking through the board artifact...");

          try {
            const response = await fetch(chatCard.dataset.aiChatEndpoint || "/api/ai/chat", {
              method: "POST",
              headers: { "content-type": "application/json" },
              body: JSON.stringify({
                release: chatCard.dataset.aiRelease,
                message,
                history: chatHistory.slice(-8)
              })
            });
            const payload = await response.json();

            if (!response.ok || !payload.ok) {
              throw new Error(payload.message || `AI chat failed with HTTP ${response.status}`);
            }

            appendChatMessage("assistant", payload.answer, { payload });
            chatStatus.textContent = payload.warning
              ? "Answer ready from deterministic board data fallback."
              : `Answer ready from ${payload.provider || "HQ AI"}.`;
          } catch (error) {
            appendChatMessage("assistant", {
              answer: `I could not reach the HQ AI chat endpoint: ${error.message}. Open the Cloudflare HQ URL and try again.`,
              highlights: ["No Jira, Slack, or automation action was performed."],
              tickets: [],
              sprint: null,
              followUps: ["Try again after refreshing the Cloudflare HQ page."],
              sourceNotes: ["The chat endpoint did not return a usable response."]
            }, { recordHistory: false, error: true });
            chatStatus.textContent = "AI chat endpoint unavailable.";
          } finally {
            setChatBusy(false);
          }
        });
      }

      function setChatBusy(isBusy, message = "") {
        if (!chatCard || !chatSend || !chatInput || !chatStatus) return;
        chatCard.classList.toggle("is-loading", isBusy);
        chatSend.disabled = isBusy;
        chatInput.disabled = isBusy;
        if (message) {
          chatStatus.textContent = message;
        }
      }

      function appendChatMessage(role, content, options = {}) {
        if (!chatLog) return;
        const isUser = role === "user";
        const bubble = document.createElement("article");
        bubble.className = `ai-chat-message ${isUser ? "user" : "assistant"}${options.error ? " has-error" : ""}`;

        const header = document.createElement("div");
        header.className = "ai-chat-message-heading";
        const title = document.createElement("strong");
        title.textContent = isUser ? "You" : options.intro ? "HQ AI agent" : "HQ AI";
        const meta = document.createElement("span");
        meta.textContent = isUser ? "Question" : options.payload?.provider || "Board-aware assistant";
        header.append(title, meta);
        bubble.appendChild(header);

        if (isUser) {
          const p = document.createElement("p");
          p.textContent = content;
          bubble.appendChild(p);
          chatHistory.push({ role: "user", content });
        } else {
          renderChatAnswer(bubble, content || {}, options.payload || null);
          if (options.recordHistory !== false) {
            chatHistory.push({ role: "assistant", content: buildChatCopyText(content || {}, options.payload || null) });
          }
        }

        while (chatHistory.length > 10) {
          chatHistory.shift();
        }

        chatLog.appendChild(bubble);
        chatLog.scrollTop = chatLog.scrollHeight;
      }

      function appendInlineAiText(target, value) {
        const text = String(value || "");
        const segments = text.split(/(\*\*[^*]+\*\*)/g);

        segments.forEach((segment) => {
          if (!segment) return;
          const boldMatch = segment.match(/^\*\*([^*]+)\*\*$/);

          if (boldMatch) {
            const strong = document.createElement("strong");
            strong.textContent = boldMatch[1];
            target.appendChild(strong);
          } else {
            target.appendChild(document.createTextNode(segment));
          }
        });
      }

      function renderChatAnswer(bubble, answer, payload) {
        const answerText = answer.answer || "No answer returned.";
        const shell = document.createElement("section");
        shell.className = "ai-chat-response-shell";

        const hero = document.createElement("div");
        hero.className = "ai-chat-response-hero";
        const icon = document.createElement("span");
        icon.className = "ai-chat-response-icon";
        icon.textContent = "✨";
        const heroBody = document.createElement("div");
        const eyebrow = document.createElement("span");
        eyebrow.className = "ai-chat-eyebrow";
        eyebrow.textContent = `${payload?.provider || "Cloudflare Workers AI"} · ${payload?.model || "HQ model"}`;
        const answerHeading = document.createElement("h4");
        answerHeading.textContent = "HQ AI answer";
        const answerParagraph = document.createElement("p");
        appendInlineAiText(answerParagraph, answerText);
        heroBody.append(eyebrow, answerHeading, answerParagraph);
        hero.append(icon, heroBody);
        shell.appendChild(hero);

        const facts = document.createElement("div");
        facts.className = "ai-chat-facts";
        const scopeLabel = payload?.scope?.label || "";
        const pullLabel = payload?.scope?.pulledAt || payload?.source?.pulledAtDisplay || "";
        const countLabel = payload?.exactLookup ? `${payload.exactLookup.count} matched` : "";
        [scopeLabel, pullLabel, countLabel].filter(Boolean).forEach((fact) => {
          const span = document.createElement("span");
          span.textContent = fact;
          facts.appendChild(span);
        });
        if (facts.children.length) {
          shell.appendChild(facts);
        }

        renderChatInsightGrid(shell, answer.highlights);

        const shouldShowSprint = payload?.scope?.kind === "sprint"
          || (!payload?.exactLookup && !payload?.conversationIntent && answer.sprint?.total);
        if (shouldShowSprint) {
          renderChatSprintSection(shell, answer.sprint);
        }

        if (Array.isArray(answer.tickets) && answer.tickets.length) {
          const ticketSection = document.createElement("section");
          ticketSection.className = "ai-chat-section ai-chat-ticket-section";
          const heading = document.createElement("h4");
          heading.textContent = `📌 Ticket table (${answer.tickets.length})`;
          const tableWrap = document.createElement("div");
          tableWrap.className = "ai-ticket-table-wrap";
          renderTicketList(tableWrap, answer.tickets);
          ticketSection.append(heading, tableWrap);
          shell.appendChild(ticketSection);
        }

        renderChatListSection(shell, "💡 Try next", answer.followUps, true);
        renderChatSourceNotes(shell, answer.sourceNotes, payload);

        const actions = document.createElement("div");
        actions.className = "ai-chat-message-actions";
        const copy = document.createElement("button");
        copy.type = "button";
        copy.textContent = "Copy answer";
        copy.addEventListener("click", async () => {
          try {
            await navigator.clipboard.writeText(buildChatCopyText(answer, payload));
            chatStatus.textContent = "Chat answer copied.";
          } catch {
            chatStatus.textContent = "Copy failed. Select the answer manually.";
          }
        });
        actions.appendChild(copy);
        shell.appendChild(actions);
        bubble.appendChild(shell);
      }

      function renderChatInsightGrid(container, items) {
        const cleanItems = Array.isArray(items) ? items.filter(Boolean) : [];
        if (!cleanItems.length) return;

        const section = document.createElement("section");
        section.className = "ai-chat-section ai-chat-insight-section";
        const heading = document.createElement("h4");
        heading.textContent = "🎯 Highlights";
        const grid = document.createElement("div");
        grid.className = "ai-chat-insight-grid";

        cleanItems.slice(0, 6).forEach((item, index) => {
          const card = document.createElement("article");
          card.className = "ai-chat-insight-card";
          const badge = document.createElement("span");
          badge.textContent = String(index + 1);
          const text = document.createElement("p");
          appendInlineAiText(text, item);
          card.append(badge, text);
          grid.appendChild(card);
        });

        section.append(heading, grid);
        container.appendChild(section);
      }

      function renderChatListSection(container, title, items, asPromptButtons = false) {
        const cleanItems = Array.isArray(items) ? items.filter(Boolean) : [];
        if (!cleanItems.length) return;

        const section = document.createElement("section");
        section.className = "ai-chat-section";
        const heading = document.createElement("h4");
        heading.textContent = title;
        section.appendChild(heading);

        if (asPromptButtons) {
          const promptWrap = document.createElement("div");
          promptWrap.className = "ai-chat-followups";
          cleanItems.slice(0, 5).forEach((item) => {
            const button = document.createElement("button");
            button.type = "button";
            button.textContent = item;
            button.addEventListener("click", () => {
              if (!chatInput) return;
              chatInput.value = item;
              chatInput.focus();
            });
            promptWrap.appendChild(button);
          });
          section.appendChild(promptWrap);
        } else {
          const list = document.createElement("ul");
          cleanItems.slice(0, 8).forEach((item) => {
            const li = document.createElement("li");
            appendInlineAiText(li, item);
            list.appendChild(li);
          });
          section.appendChild(list);
        }

        container.appendChild(section);
      }

      function renderChatSprintSection(container, sprint) {
        if (!sprint || (!sprint.total && !sprint.name && !sprint.label)) {
          return;
        }

        const section = document.createElement("section");
        section.className = "ai-chat-section ai-chat-sprint-section";
        const heading = document.createElement("h4");
        heading.textContent = "🧭 Sprint context";
        const dl = document.createElement("dl");
        [
          ["Sprint", sprint.label || sprint.name || "Sprint view"],
          ["Work items", sprint.total ? String(sprint.total) : ""],
          ["Priority mix", Array.isArray(sprint.priorityMix) ? sprint.priorityMix.join(", ") : ""],
          ["Status mix", Array.isArray(sprint.statusMix) ? sprint.statusMix.slice(0, 5).join(", ") : ""],
          ["Window", sprint.dateWindow || ""]
        ].filter(([, value]) => value).forEach(([label, value]) => {
          const div = document.createElement("div");
          const dt = document.createElement("dt");
          const dd = document.createElement("dd");
          dt.textContent = label;
          dd.textContent = value;
          div.append(dt, dd);
          dl.appendChild(div);
        });
        section.append(heading, dl);
        container.appendChild(section);
      }

      function renderChatSourceNotes(container, items, payload) {
        const cleanItems = Array.isArray(items) ? items.filter(Boolean) : [];
        const warning = payload?.warning || "";
        if (!cleanItems.length && !warning) return;

        const details = document.createElement("details");
        details.className = "ai-chat-sources";
        const summary = document.createElement("summary");
        summary.textContent = "🔎 Sources and guardrails";
        const list = document.createElement("ul");

        [...cleanItems, warning].filter(Boolean).slice(0, 8).forEach((item) => {
          const li = document.createElement("li");
          appendInlineAiText(li, item);
          list.appendChild(li);
        });

        details.append(summary, list);
        container.appendChild(details);
      }

      function buildChatCopyText(answer, payload) {
        const lines = [
          answer.answer || "HQ AI answer",
          "",
          payload?.scope?.label ? `Scope: ${payload.scope.label}` : "",
          payload?.scope?.pulledAt ? `Artifact pull: ${payload.scope.pulledAt}` : "",
          "",
          Array.isArray(answer.highlights) && answer.highlights.length ? "Highlights:" : "",
          Array.isArray(answer.highlights) && answer.highlights.length ? toBulletList(answer.highlights) : "",
          "",
          Array.isArray(answer.tickets) && answer.tickets.length ? "Tickets:" : "",
          Array.isArray(answer.tickets) && answer.tickets.length ? buildLeadershipTicketTable(answer.tickets) : "",
          "",
          Array.isArray(answer.followUps) && answer.followUps.length ? "Follow-ups:" : "",
          Array.isArray(answer.followUps) && answer.followUps.length ? toBulletList(answer.followUps) : ""
        ];

        return lines.filter((line, index, source) => line || source[index - 1]).join("\n").trim();
      }

      function renderBrief(payload) {
        const brief = payload.brief || {};
        const source = payload.source || {};
        const answerType = payload.answerType || brief.answerType || "release_brief";
        resultCard.hidden = false;
        setResultLabels(answerType);
        resultTitle.textContent = brief.title || "Draft release brief";
        resultMeta.textContent = `${payload.provider || "Cloudflare Workers AI"} / ${payload.model || "unknown model"}`;
        resultSource.textContent = `${payload.release || "release"} / pulled ${source.pulledAtDisplay || source.pulledAt || "unknown"}`;
        resultSummary.textContent = brief.summary || "";
        renderList(riskList, brief.topRisks);
        renderList(focusList, brief.qaFocus);
        renderTicketList(ticketList, brief.ticketsToWatch || []);
        renderList(gateList, brief.reviewGates);
        renderGeneratedDocuments(documentsPanel, brief.generatedDocuments || []);
        latestBriefText = buildBriefText(payload);
        if (copyButton) copyButton.disabled = !latestBriefText;
      }

      function setResultLabels(answerType) {
        const lookupMode = answerType === "assignee_lookup" || answerType === "comment_file_lookup" || answerType === "component_lookup" || answerType === "priority_lookup" || answerType === "ticket_lookup" || answerType === "direct_lookup";
        const testPlanMode = answerType === "ticket_test_plan";
        const freeFormMode = answerType === "free_form";
        const rundownMode = answerType === "main_ticket_rundown";

        if (riskTitle) riskTitle.textContent = rundownMode ? "Leadership summary" : testPlanMode ? "Coverage risks" : lookupMode ? "AI lookup insights" : freeFormMode ? "Key findings" : "Top risks";
        if (focusTitle) focusTitle.textContent = rundownMode ? "Board context" : testPlanMode ? "Test scenarios" : lookupMode ? "Matched ticket analysis" : freeFormMode ? "Answer details" : "QA focus";
        if (ticketTitle) ticketTitle.textContent = rundownMode ? "Main ticket rundown" : testPlanMode ? "Related tickets" : lookupMode ? "Ticket links" : freeFormMode ? "Relevant tickets" : "Tickets to watch";
        if (gateTitle) gateTitle.textContent = rundownMode ? "Review before sharing" : "Review gates";
      }

      function renderList(list, items) {
        if (!list) return;
        list.textContent = "";
        const cleanItems = Array.isArray(items) && items.length ? items : ["No items returned."];

        cleanItems.forEach((item) => {
          const li = document.createElement("li");
          li.textContent = item;
          list.appendChild(li);
        });
      }

      function renderTicketList(list, tickets) {
        if (!list) return;
        list.textContent = "";
        const cleanTickets = Array.isArray(tickets) && tickets.length ? tickets : [];

        if (!cleanTickets.length) {
          const empty = document.createElement("p");
          empty.className = "ai-ticket-empty";
          empty.textContent = "No tickets returned.";
          list.appendChild(empty);
          return;
        }

        const table = document.createElement("table");
        table.className = "ai-ticket-table";

        const colgroup = document.createElement("colgroup");
        ["ticket", "summary", "status", "priority", "assignee", "developer"].forEach((name) => {
          const col = document.createElement("col");
          col.className = `ai-ticket-col-${name}`;
          colgroup.appendChild(col);
        });

        const thead = document.createElement("thead");
        const headerRow = document.createElement("tr");
        ["Ticket", "Summary", "Status", "Priority", "Assignee", "Assigned developer"].forEach((label) => {
          const th = document.createElement("th");
          th.scope = "col";
          th.textContent = label;
          headerRow.appendChild(th);
        });
        thead.appendChild(headerRow);

        const tbody = document.createElement("tbody");
        cleanTickets.forEach((ticket) => {
          const tr = document.createElement("tr");
          const ticketCell = document.createElement("td");
          const title = document.createElement(ticket.url ? "a" : "strong");
          title.textContent = ticket.key || "Unknown";

          if (ticket.url) {
            title.href = ticket.url;
            title.target = "_blank";
            title.rel = "noopener";
          }

          const type = document.createElement("span");
          type.textContent = ticket.type || (ticket.parent ? "Subtask" : "Ticket");
          ticketCell.append(title, type);

          const summaryCell = document.createElement("td");
          const summaryText = document.createElement("strong");
          summaryText.textContent = ticket.summary || "No summary";
          summaryCell.appendChild(summaryText);

          const metadata = [
            Array.isArray(ticket.components) && ticket.components.length ? `Components: ${ticket.components.join(", ")}` : "",
            Array.isArray(ticket.fixVersions) && ticket.fixVersions.length ? `Fix: ${ticket.fixVersions.join(", ")}` : "",
            Array.isArray(ticket.sprintNames) && ticket.sprintNames.length ? `Sprint: ${ticket.sprintNames.join(", ")}` : "",
            ticket.parent ? `Parent: ${ticket.parent}` : ""
          ].filter(Boolean);

          if (metadata.length) {
            const meta = document.createElement("span");
            meta.textContent = metadata.join(" | ");
            summaryCell.appendChild(meta);
          }

          const statusCell = document.createElement("td");
          statusCell.appendChild(buildAiTicketPill(ticket.status || "Unknown", "status"));

          const priorityCell = document.createElement("td");
          priorityCell.appendChild(buildAiTicketPill(ticket.priority || "None", "priority"));

          const assigneeCell = document.createElement("td");
          assigneeCell.textContent = ticket.assignee || "Unassigned";

          const developerCell = document.createElement("td");
          developerCell.textContent = ticket.assignedDeveloper || "Unassigned";

          tr.append(ticketCell, summaryCell, statusCell, priorityCell, assigneeCell, developerCell);
          tbody.appendChild(tr);
        });

        table.append(colgroup, thead, tbody);
        list.appendChild(table);
      }

      function buildAiTicketPill(label, type) {
        const pill = document.createElement("span");
        pill.className = `ai-ticket-pill ${type}`;
        pill.textContent = label;
        return pill;
      }

      function renderGeneratedDocuments(panel, documents) {
        if (!panel) return;
        panel.textContent = "";
        const cleanDocuments = Array.isArray(documents) ? documents.filter((document) => document?.markdown) : [];
        panel.hidden = !cleanDocuments.length;

        cleanDocuments.forEach((generatedDoc) => {
          const article = document.createElement("article");
          article.className = "ai-generated-document";

          const header = document.createElement("div");
          header.className = "generated-document-heading";

          const titleWrap = document.createElement("div");
          const eyebrow = document.createElement("p");
          eyebrow.className = "eyebrow";
          eyebrow.textContent = generatedDoc.filename || "Generated markdown file";
          const title = document.createElement("h4");
          title.textContent = generatedDoc.title || "Generated file preview";
          const subtitle = document.createElement("p");
          subtitle.textContent = generatedDoc.subtitle || "Rendered from parsed markdown checklist data.";
          titleWrap.append(eyebrow, title, subtitle);

          const meta = document.createElement("span");
          meta.textContent = `${generatedDoc.ticketKey || "Ticket"} / ${generatedDoc.caseCount || 0} cases`;
          header.append(titleWrap, meta);

          const body = document.createElement("div");
          body.className = "generated-markdown-body";
          renderMarkdownPreview(body, generatedDoc.markdown);

          article.append(header, body);
          panel.appendChild(article);
        });
      }

      function renderMarkdownPreview(container, markdown) {
        container.textContent = "";
        let list = null;
        let listType = "";

        const closeList = () => {
          list = null;
          listType = "";
        };

        String(markdown || "").split(/\r?\n/).forEach((line) => {
          const trimmed = line.trim();

          if (!trimmed) {
            closeList();
            return;
          }

          if (/^-{3,}$/.test(trimmed)) {
            closeList();
            container.appendChild(document.createElement("hr"));
            return;
          }

          const heading = trimmed.match(/^(#{1,4})\s+(.+)$/);
          if (heading) {
            closeList();
            const level = Math.min(heading[1].length + 1, 5);
            const element = document.createElement(`h${level}`);
            appendInlineMarkdown(element, heading[2]);
            container.appendChild(element);
            return;
          }

          const bullet = trimmed.match(/^[-*]\s+(.+)$/);
          const numbered = trimmed.match(/^\d+\.\s+(.+)$/);
          if (bullet || numbered) {
            const nextType = bullet ? "ul" : "ol";
            if (!list || listType !== nextType) {
              list = document.createElement(nextType);
              listType = nextType;
              container.appendChild(list);
            }

            const li = document.createElement("li");
            appendInlineMarkdown(li, bullet ? bullet[1] : numbered[1]);
            list.appendChild(li);
            return;
          }

          closeList();
          const paragraph = document.createElement("p");
          appendInlineMarkdown(paragraph, trimmed);
          container.appendChild(paragraph);
        });
      }

      function appendInlineMarkdown(element, text) {
        const source = String(text || "");
        const pattern = /(\*\*[^*]+\*\*|\[[^\]]+\]\([^)]+\))/g;
        let index = 0;

        source.replace(pattern, (match, _token, offset) => {
          if (offset > index) {
            element.appendChild(document.createTextNode(source.slice(index, offset)));
          }

          if (match.startsWith("**")) {
            const strong = document.createElement("strong");
            strong.textContent = match.slice(2, -2);
            element.appendChild(strong);
          } else {
            const linkMatch = match.match(/^\[([^\]]+)\]\(([^)]+)\)$/);
            const link = document.createElement("a");
            link.textContent = linkMatch?.[1] || match;
            link.href = linkMatch?.[2] || "#";
            link.target = "_blank";
            link.rel = "noopener";
            element.appendChild(link);
          }

          index = offset + match.length;
          return match;
        });

        if (index < source.length) {
          element.appendChild(document.createTextNode(source.slice(index)));
        }
      }

      function buildBriefText(payload) {
        const brief = payload.brief || {};
        const answerType = payload.answerType || brief.answerType || "release_brief";
        const lookupMode = answerType === "assignee_lookup" || answerType === "comment_file_lookup" || answerType === "component_lookup" || answerType === "priority_lookup" || answerType === "ticket_lookup" || answerType === "direct_lookup";
        const testPlanMode = answerType === "ticket_test_plan";
        const freeFormMode = answerType === "free_form";
        const rundownMode = answerType === "main_ticket_rundown";
        const tickets = (brief.ticketsToWatch || []).map(formatTicketForCopy).join("\n");
        const documents = Array.isArray(brief.generatedDocuments) && brief.generatedDocuments.length
          ? brief.generatedDocuments.map((document) => document.markdown).join("\n\n---\n\n")
          : "";

        if (rundownMode) {
          return [
            brief.title || "Leadership main-ticket rundown",
            "",
            brief.summary || "",
            "",
            "Main tickets:",
            buildLeadershipTicketTable(brief.ticketsToWatch || []),
            "",
            "Leadership summary:",
            toBulletList(brief.topRisks),
            "",
            "Board context:",
            toBulletList(brief.qaFocus),
            "",
            "Review before sharing:",
            toBulletList(brief.reviewGates),
            "",
            `Source: ${payload.release || "release"} / ${payload.source?.pulledAtDisplay || payload.source?.pulledAt || "unknown pull"}`
          ].join("\n");
        }

        return [
          brief.title || "Draft release brief",
          "",
          brief.summary || "",
          "",
          testPlanMode ? "Coverage risks:" : lookupMode ? "AI lookup insights:" : freeFormMode ? "Key findings:" : "Top risks:",
          toBulletList(brief.topRisks),
          "",
          testPlanMode ? "Test scenarios:" : lookupMode ? "Matched ticket analysis:" : freeFormMode ? "Answer details:" : "QA focus:",
          toBulletList(brief.qaFocus),
          "",
          testPlanMode ? "Related tickets:" : lookupMode ? "Ticket links:" : freeFormMode ? "Relevant tickets:" : "Tickets to watch:",
          tickets || "- No tickets returned.",
          "",
          "Review gates:",
          toBulletList(brief.reviewGates),
          documents ? "\nGenerated file preview:" : "",
          documents,
          "",
          `Source: ${payload.release || "release"} / ${payload.source?.pulledAtDisplay || payload.source?.pulledAt || "unknown pull"}`
        ].join("\n");
      }

      function toBulletList(items) {
        return Array.isArray(items) && items.length ? items.map((item) => `- ${item}`).join("\n") : "- No items returned.";
      }

      function buildLeadershipTicketTable(tickets) {
        const cleanTickets = Array.isArray(tickets) && tickets.length ? tickets : [];

        if (!cleanTickets.length) {
          return "_No main tickets returned._";
        }

        const rows = cleanTickets.map((ticket) => {
          const key = ticket.key || "Unknown";
          const ticketCell = ticket.url ? `[${key}](${ticket.url})` : key;
          return [
            ticketCell,
            ticket.summary || "",
            ticket.status || "Unknown",
            ticket.priority || "None",
            ticket.assignee || "Unassigned",
            ticket.assignedDeveloper || "Unassigned"
          ].map(escapeMarkdownTableCell).join(" | ");
        });

        return [
          "| Ticket | Summary | Status | Priority | Assignee | Assigned Developer |",
          "| --- | --- | --- | --- | --- | --- |",
          ...rows.map((row) => `| ${row} |`)
        ].join("\n");
      }

      function escapeMarkdownTableCell(value) {
        return String(value || "")
          .replace(/\r?\n/g, " ")
          .replace(/\|/g, "\\|")
          .trim();
      }

      function formatTicketForCopy(ticket) {
        const key = ticket.key || "Unknown";
        const title = ticket.url ? `[${key}](${ticket.url})` : key;
        const summary = ticket.summary ? ` - ${ticket.summary}` : "";
        const metadata = [
          ticket.type,
          ticket.status,
          ticket.priority,
          ticket.assignee ? `Assignee: ${ticket.assignee}` : "",
          ticket.assignedDeveloper ? `Dev: ${ticket.assignedDeveloper}` : "",
          Array.isArray(ticket.components) && ticket.components.length ? `Components: ${ticket.components.join(", ")}` : "",
          Array.isArray(ticket.fixVersions) && ticket.fixVersions.length ? `Fix: ${ticket.fixVersions.join(", ")}` : "",
          Array.isArray(ticket.sprintNames) && ticket.sprintNames.length ? `Sprint: ${ticket.sprintNames.join(", ")}` : "",
          ticket.parent ? `Parent: ${ticket.parent}` : ""
        ].filter(Boolean).join(" | ");
        return `- ${title}${summary}${metadata ? ` (${metadata})` : ""}${ticket.reason ? ` - ${ticket.reason}` : ""}`;
      }
    })();
  </script>

  <script is:inline>
    (() => {
      const runner = document.querySelector(".slack-runner-card");
      if (!runner) return;

      const statusEndpoint = runner.dataset.slackStatusEndpoint || "/api/slack/status";
      const sendEndpoint = runner.dataset.slackSendEndpoint || "/api/slack/send";
      const activityEndpoint = runner.dataset.slackActivityEndpoint || "/api/slack/activity";
      const statusText = document.querySelector("#hq-slack-status");
      const modeText = document.querySelector("#hq-slack-mode");
      const dot = document.querySelector("#hq-slack-dot");
      const refreshButton = document.querySelector("#hq-slack-refresh");
      const sendButton = document.querySelector("#hq-slack-send");
      const messageInput = document.querySelector("#hq-slack-message");
      const outboundLabel = document.querySelector("#hq-slack-outbound");
      const outboundDetail = document.querySelector("#hq-slack-outbound-detail");
      const inboundLabel = document.querySelector("#hq-slack-inbound");
      const inboundDetail = document.querySelector("#hq-slack-inbound-detail");
      const commandUrl = document.querySelector("#hq-slack-url-command");
      const eventsUrl = document.querySelector("#hq-slack-url-events");
      const actionsUrl = document.querySelector("#hq-slack-url-actions");
      const activityRefreshButton = document.querySelector("#hq-slack-activity-refresh");
      const activityList = document.querySelector("#hq-slack-activity-list");
      let latestStatus = null;

      checkSlackStatus();
      loadSlackActivity();

      refreshButton?.addEventListener("click", checkSlackStatus);
      sendButton?.addEventListener("click", sendSlackMessage);
      activityRefreshButton?.addEventListener("click", loadSlackActivity);
      window.setInterval(loadSlackActivity, 45000);

      async function checkSlackStatus() {
        setSlackBusy("Checking Slack Worker route...");

        try {
          const response = await fetch(statusEndpoint, { cache: "no-store" });
          const payload = await response.json();

          if (!response.ok || !payload.ok) {
            throw new Error(payload.message || `Slack status failed with HTTP ${response.status}`);
          }

          latestStatus = payload;
          const channel = payload.channelName ? `#${payload.channelName.replace(/^#/, "")}` : payload.channel || runner.dataset.slackChannel || "Slack channel";
          updateSlackFacts(payload, channel);
          if (payload.canPost && payload.canReceive) {
            setSlackState("ready", "Two-way ready", `Slack bot route can post to ${channel} and receive verified Slack callbacks.`, true);
          } else if (payload.canPost) {
            setSlackState("missing", "Outbound ready", `Posting to ${channel} works. Add SLACK_SIGNING_SECRET and Slack Request URLs to enable inbound callbacks.`, true);
          } else if (payload.tokenConfigured === false) {
            setSlackState("missing", "Token missing", "Add the SLACK_BOT_TOKEN Worker secret before posting from HQ.", false);
          } else {
            setSlackState("missing", "Config missing", payload.message || "Slack notifier needs Worker configuration before posting.", false);
          }
        } catch (error) {
          latestStatus = null;
          setSlackState("error", "Unavailable", `Slack Worker route unavailable: ${error.message}. Use the Cloudflare HQ URL for live /api/slack routes.`, false);
        }
      }

      async function sendSlackMessage() {
        const message = messageInput?.value?.trim() || "";
        if (!message) {
          setSlackState("error", "Message needed", "Write a Slack message before sending.", false);
          return;
        }

        if (!latestStatus?.canPost) {
          await checkSlackStatus();
          if (!latestStatus?.canPost) return;
        }

        sendButton.disabled = true;
        setSlackBusy("Posting through CORE JIRA NOTIFIER AGENT...");

        try {
          const response = await fetch(sendEndpoint, {
            method: "POST",
            headers: { "content-type": "application/json" },
            body: JSON.stringify({
              message,
              context: {
                source: "core-qa-hq",
                release: "v3001.124.0",
                channel: runner.dataset.slackChannel || "#core-qa-dream-team"
              }
            })
          });
          const payload = await response.json();

          if (!response.ok || !payload.ok) {
            throw new Error(payload.message || payload.slackError || `Slack post failed with HTTP ${response.status}`);
          }

          setSlackState("ready", "Posted", `Slack message posted at ${payload.ts || "the latest timestamp"}.`, true);
          loadSlackActivity();
        } catch (error) {
          setSlackState("error", "Post failed", error.message, true);
        } finally {
          sendButton.disabled = !latestStatus?.canPost;
        }
      }

      function setSlackBusy(message) {
        if (statusText) statusText.textContent = message;
        if (modeText) modeText.textContent = "Checking";
        runner.classList.remove("is-ready", "is-missing", "has-error");
        runner.classList.add("is-loading");
        if (sendButton) sendButton.disabled = true;
        if (dot) dot.setAttribute("data-state", "loading");
      }

      function setSlackState(state, mode, message, canSend = state === "ready") {
        runner.classList.remove("is-loading", "is-ready", "is-missing", "has-error");
        runner.classList.add(state === "ready" ? "is-ready" : state === "missing" ? "is-missing" : "has-error");
        if (modeText) modeText.textContent = mode;
        if (statusText) statusText.textContent = message;
        if (sendButton) sendButton.disabled = !canSend;
        if (dot) dot.setAttribute("data-state", state);
      }

      function updateSlackFacts(payload, channel) {
        setText(outboundLabel, payload.canPost ? "Ready" : "Not ready");
        setText(outboundDetail, payload.canPost
          ? `HQ can post reviewed updates to ${channel}.`
          : payload.tokenConfigured === false
            ? "SLACK_BOT_TOKEN is missing."
            : "Slack channel or token configuration needs review.");
        setText(inboundLabel, payload.canReceive ? "Ready" : "Setup needed");
        setText(inboundDetail, payload.canReceive
          ? "Slack callbacks can be verified with SLACK_SIGNING_SECRET."
          : "Add SLACK_SIGNING_SECRET, then paste these Request URLs into the Slack app.");

        setText(commandUrl, payload.requestUrls?.slashCommand || "/api/slack/commands");
        setText(eventsUrl, payload.requestUrls?.events || "/api/slack/events");
        setText(actionsUrl, payload.requestUrls?.interactivity || "/api/slack/actions");
      }

      async function loadSlackActivity() {
        if (!activityList) return;

        try {
          const response = await fetch(activityEndpoint, { cache: "no-store" });
          const payload = await response.json();

          if (!response.ok || !payload.ok) {
            throw new Error(payload.message || `Slack activity failed with HTTP ${response.status}`);
          }

          renderSlackActivity(Array.isArray(payload.events) ? payload.events : []);
        } catch (error) {
          activityList.innerHTML = `<li>Slack activity unavailable: ${escapeHtml(error.message)}</li>`;
        }
      }

      function renderSlackActivity(events) {
        if (!activityList) return;

        if (!events.length) {
          activityList.innerHTML = "<li>No inbound Slack activity has been recorded in this Worker instance yet.</li>";
          return;
        }

        activityList.innerHTML = events.map((event) => {
          const label = [event.type, event.status].filter(Boolean).join(" / ");
          const meta = [formatActivityTime(event.at), event.user, event.channel].filter(Boolean).join(" · ");
          const text = event.text ? `<p>${escapeHtml(event.text)}</p>` : "";
          const detail = event.detail ? `<small>${escapeHtml(event.detail)}</small>` : "";
          return `<li><strong>${escapeHtml(label)}</strong><span>${escapeHtml(meta)}</span>${text}${detail}</li>`;
        }).join("");
      }

      function setText(element, value) {
        if (element) element.textContent = value;
      }

      function formatActivityTime(value) {
        if (!value) return "";
        const date = new Date(value);
        return Number.isNaN(date.getTime()) ? value : date.toLocaleTimeString([], { hour: "numeric", minute: "2-digit" });
      }

      function escapeHtml(value) {
        return String(value || "").replace(/[&<>"']/g, (char) => ({
          "&": "&amp;",
          "<": "&lt;",
          ">": "&gt;",
          "\"": "&quot;",
          "'": "&#39;"
        }[char]));
      }
    })();
  </script>

  <script is:inline>
    (() => {
      const calendarConsole = document.querySelector(".calendar-console");
      if (!calendarConsole) return;

      const dataUrl = calendarConsole.getAttribute("data-calendar-data-url") || "/dashboard-data.json";
      const openSourceLink = document.querySelector("#calendar-open-source");
      const activeTitle = document.querySelector("#calendar-active-title");
      const activeSummary = document.querySelector("#calendar-active-summary");
      const cadenceLabel = document.querySelector("#calendar-refresh-cadence");
      const lastPullLabel = document.querySelector("#calendar-last-pull");
      const windowLabel = document.querySelector("#calendar-window");
      const alertBox = document.querySelector("#calendar-alert");
      const monthView = document.querySelector("#calendar-month-view");
      const listView = document.querySelector("#calendar-list-view");
      const monthTitle = document.querySelector("#calendar-month-title");
      const eventCount = document.querySelector("#calendar-event-count");
      const calendarGrid = document.querySelector("#calendar-grid");
      const viewButtons = Array.from(document.querySelectorAll("[data-calendar-view]"));
      const monthButtons = Array.from(document.querySelectorAll("[data-calendar-month]"));

      let calendarData = null;
      let activeSourceId = "";
      let activeView = "calendar";
      let visibleMonthDate = startOfMonth(new Date());
      let refreshTimer = 0;

      function cacheBustedDataUrl() {
        const url = new URL(dataUrl, window.location.href);
        url.searchParams.set("calendarRefresh", Date.now().toString());
        return url.toString();
      }

      async function loadCalendarData() {
        try {
          const response = await fetch(cacheBustedDataUrl(), { cache: "no-store" });
          if (!response.ok) {
            throw new Error(`HTTP ${response.status} loading dashboard-data.json`);
          }
          const dashboard = await response.json();
          calendarData = dashboard.calendarMenu || null;
          if (!calendarData) {
            throw new Error("The deployed dashboard artifact does not include calendarMenu yet.");
          }
          if (!activeSourceId) {
            activeSourceId = calendarData.defaultSourceId || calendarData.sources?.[0]?.id || "";
          }
          renderCalendar();
          scheduleCalendarRefresh();
        } catch (error) {
          showCalendarError(`Calendar data could not be loaded: ${error.message}`);
        }
      }

      function scheduleCalendarRefresh() {
        window.clearTimeout(refreshTimer);
        const seconds = Math.max(60, Number(calendarData?.refreshSeconds || 300));
        refreshTimer = window.setTimeout(loadCalendarData, seconds * 1000);
      }

      function getActiveSource() {
        const sources = Array.isArray(calendarData?.sources) ? calendarData.sources : [];
        return sources.find((source) => source.id === activeSourceId) || sources[0] || null;
      }

      function renderCalendar() {
        const source = getActiveSource();
        if (!source) {
          showCalendarError("No calendar sources are configured.");
          return;
        }

        activeTitle.textContent = source.name || "Release calendar";
        activeSummary.textContent = source.description || "Events are pulled from the Confluence Team Calendar during the board refresh.";
        cadenceLabel.textContent = `Every ${Math.round(Number(calendarData.refreshSeconds || 300) / 60)} min`;
        lastPullLabel.textContent = `${calendarData.pulledAtDisplay || calendarData.pulledAt || "Unknown"} ET`;
        windowLabel.textContent = `${calendarData.window?.startDisplay || "start"} - ${calendarData.window?.endDisplay || "end"} ET`;
        openSourceLink.href = source.url || "#";

        if (source.status === "error") {
          showCalendarError(`${source.name || "Calendar"} needs attention: ${source.error || "Confluence did not return events."}`);
        } else {
          hideCalendarAlert();
        }

        renderViewButtons();
        renderMonth(source);
        renderList(source);
        monthView.hidden = activeView !== "calendar";
        listView.hidden = activeView !== "upcoming";
      }

      function renderViewButtons() {
        viewButtons.forEach((button) => {
          const selected = button.getAttribute("data-calendar-view") === activeView;
          button.classList.toggle("active", selected);
          button.setAttribute("aria-selected", selected ? "true" : "false");
        });
      }

      function showCalendarError(message) {
        alertBox.hidden = false;
        alertBox.textContent = message;
      }

      function showCalendarInfo(message) {
        alertBox.hidden = false;
        alertBox.textContent = message;
      }

      function hideCalendarAlert() {
        alertBox.hidden = true;
        alertBox.textContent = "";
      }

      function renderMonth(source) {
        const events = Array.isArray(source.events) ? source.events : [];
        const basisDate = visibleMonthDate || startOfMonth(new Date());
        const year = basisDate.getFullYear();
        const month = basisDate.getMonth();
        const firstOfMonth = new Date(year, month, 1);
        const start = new Date(firstOfMonth);
        start.setDate(firstOfMonth.getDate() - firstOfMonth.getDay());
        const todayKey = dayKey(new Date());

        const monthEvents = events.filter((event) => {
          const eventDate = new Date(event.start || 0);
          return eventDate.getFullYear() === year && eventDate.getMonth() === month;
        });

        monthTitle.textContent = new Intl.DateTimeFormat("en-US", { month: "long", year: "numeric" }).format(firstOfMonth);
        eventCount.textContent = `${monthEvents.length} event${monthEvents.length === 1 ? "" : "s"} this month`;
        calendarGrid.textContent = "";

        for (let index = 0; index < 42; index += 1) {
          const day = new Date(start);
          day.setDate(start.getDate() + index);
          const key = dayKey(day);
          const cell = document.createElement("article");
          cell.className = "calendar-day";
          if (day.getMonth() !== month) cell.classList.add("muted");
          if (key === todayKey) cell.classList.add("today");

          const number = document.createElement("span");
          number.className = "calendar-day-number";
          number.textContent = String(day.getDate());
          cell.appendChild(number);

          events.filter((event) => dayKey(new Date(event.start || 0)) === key).slice(0, 3).forEach((event) => {
            const link = document.createElement("a");
            link.className = "calendar-event-pill";
            link.href = event.url || source.url || "#";
            link.target = "_blank";
            link.rel = "noopener";
            const title = document.createElement("strong");
            title.textContent = event.title || "Release event";
            const time = document.createElement("span");
            time.textContent = event.allDay ? "All day" : formatCalendarTime(event.start);
            link.append(title, time);
            cell.appendChild(link);
          });

          calendarGrid.appendChild(cell);
        }
      }

      function renderList(source) {
        const events = Array.isArray(source.events)
          ? source.events.slice().sort((a, b) => new Date(a.start || 0) - new Date(b.start || 0))
          : [];
        listView.textContent = "";

        if (!events.length) {
          const empty = document.createElement("div");
          empty.className = "calendar-empty";
          empty.textContent = source.status === "error"
            ? "No events are available because the calendar pull needs attention."
            : "No release calendar events were returned for the configured window.";
          listView.appendChild(empty);
          return;
        }

        const groups = new Map();
        events.forEach((event) => {
          const date = new Date(event.start || 0);
          const key = monthKey(date);
          if (!groups.has(key)) {
            groups.set(key, {
              key,
              label: new Intl.DateTimeFormat("en-US", { month: "long", year: "numeric" }).format(date),
              events: [],
            });
          }
          groups.get(key).events.push(event);
        });

        Array.from(groups.values()).forEach((group) => {
          const details = document.createElement("details");
          details.className = "calendar-month-group";

          const summary = document.createElement("summary");
          const label = document.createElement("strong");
          label.textContent = group.label;
          const count = document.createElement("span");
          count.textContent = `${group.events.length} event${group.events.length === 1 ? "" : "s"}`;
          summary.append(label, count);
          details.appendChild(summary);

          group.events.forEach((event) => {
            details.appendChild(renderListEventCard(event, source));
          });

          listView.appendChild(details);
        });
      }

      function renderListEventCard(event, source) {
          const card = document.createElement("article");
          card.className = "calendar-list-card";

          const time = document.createElement("time");
          time.dateTime = event.start || "";
          time.textContent = event.startDisplay || event.start || "Date pending";

          const body = document.createElement("div");
          const title = document.createElement("h4");
          title.textContent = event.title || "Release event";
          const detail = document.createElement("p");
          detail.textContent = [
            event.type,
            event.location,
            event.description,
          ].filter(Boolean).join(" / ") || "No additional event notes were returned.";
          body.append(title, detail);

          const open = document.createElement("a");
          open.href = event.url || source.url || "#";
          open.target = "_blank";
          open.rel = "noopener";
          open.textContent = "Open";

          card.append(time, body, open);
          return card;
      }

      function dayKey(date) {
        return new Intl.DateTimeFormat("en-CA", {
          timeZone: "America/New_York",
          year: "numeric",
          month: "2-digit",
          day: "2-digit",
        }).format(date);
      }

      function formatCalendarTime(input) {
        if (!input) return "";
        return new Intl.DateTimeFormat("en-US", {
          timeZone: "America/New_York",
          hour: "numeric",
          minute: "2-digit",
        }).format(new Date(input));
      }

      function startOfMonth(date) {
        return new Date(date.getFullYear(), date.getMonth(), 1);
      }

      function addMonths(date, delta) {
        return new Date(date.getFullYear(), date.getMonth() + delta, 1);
      }

      function monthKey(date) {
        const year = date.getFullYear();
        const month = String(date.getMonth() + 1).padStart(2, "0");
        return `${year}-${month}`;
      }

      viewButtons.forEach((button) => {
        button.addEventListener("click", () => {
          activeView = button.getAttribute("data-calendar-view") || "calendar";
          renderCalendar();
        });
      });

      monthButtons.forEach((button) => {
        button.addEventListener("click", () => {
          const action = button.getAttribute("data-calendar-month");
          if (action === "previous") {
            visibleMonthDate = addMonths(visibleMonthDate, -1);
          } else if (action === "next") {
            visibleMonthDate = addMonths(visibleMonthDate, 1);
          } else {
            visibleMonthDate = startOfMonth(new Date());
          }
          activeView = "calendar";
          renderCalendar();
        });
      });

      loadCalendarData();
    })();
  </script>
</QaHqLayout>
