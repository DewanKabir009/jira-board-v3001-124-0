---

<QaHqLayout title="CORE QA Headquarters">
  <main class="hq-shell" id="hq-main">
    <aside class="hq-sidebar" aria-label="CORE QA headquarters navigation">
      <div class="hq-brand">
        <span class="brand-mark" aria-hidden="true">QA</span>
        <div>
          <p class="eyebrow">CORE</p>
          <h1>QA Headquarters</h1>
        </div>
      </div>

      <nav class="hq-nav" aria-label="HQ modules">
        <a class="active" href="#boards">Release boards</a>
        <a href="#kb">Knowledge base</a>
        <a href="#automation">Automation bench</a>
        <a href="#ai">AI summary</a>
        <a href="#status">Operations status</a>
        <a href="#access">Access control</a>
        <a href="#calendar">Calendar menu</a>
      </nav>

      <div class="side-status">
        <p class="eyebrow">Current pilot</p>
        <strong>v3001.124.0</strong>
        <span>Cloudflare migration target</span>
      </div>
    </aside>

    <section class="hq-workbench" aria-label="CORE QA HQ workbench">
      <header class="command-strip">
        <div>
          <p class="eyebrow">Test bench</p>
          <h2>CORE QA operating hub</h2>
          <p class="command-summary">Central workspace for release dashboards, test knowledge, automation evidence, AI triage, and service health.</p>
        </div>
        <div class="command-actions" aria-label="HQ quick links">
          <a href="#boards">Boards</a>
          <a href="#automation">Runbook</a>
          <a href="#specs">Specs</a>
        </div>
      </header>

      <section class="status-grid" aria-label="Operational status snapshot">
        {statusCards.map((card) => (
          <article class={`status-card ${card.tone}`}>
            <span>{card.label}</span>
            <strong>{card.value}</strong>
            <p>{card.detail}</p>
          </article>
        ))}
      </section>

      <section class="module-panel board-module" id="boards">
        <div class="module-heading">
          <div>
            <p class="eyebrow">Release boards</p>
            <h2>Dashboard command center</h2>
          </div>
          <span class="module-pill">3 releases tracked</span>
        </div>

        <div class="board-tabs" role="list" aria-label="Release dashboard shortcuts">
          {releaseBoards.map((board) => (
            <a class={board.status === "Current" ? "board-tab current" : "board-tab"} href={board.modernUrl}>
              <span>{board.label}</span>
              <strong>{board.release}</strong>
              <em>{board.status}</em>
            </a>
          ))}
        </div>

        <div class="board-grid">
          {releaseBoards.map((board) => (
            <article class={board.status === "Current" ? "board-card current" : "board-card"}>
              <div class="board-card-top">
                <div>
                  <p class="eyebrow">{board.state}</p>
                  <h3>{board.release}</h3>
                </div>
                <span>{board.status}</span>
              </div>
              <p>{board.summary}</p>
              <dl>
                <div>
                  <dt>Repository</dt>
                  <dd>{board.repo}</dd>
                </div>
              </dl>
              <div class="card-actions">
                <a href={board.modernUrl}>Modern board</a>
                <a href={board.url}>Legacy board</a>
              </div>
            </article>
          ))}
        </div>

        <article class="board-preview">
          <div class="preview-heading">
            <div>
              <p class="eyebrow">Current preview</p>
              <h3>v3001.124.0 modern dashboard</h3>
            </div>
            <a href="https://core-qa-headquarters-124.dfkabir253.workers.dev/">Open full board</a>
          </div>
          <iframe title="v3001.124.0 modern board preview" src="https://core-qa-headquarters-124.dfkabir253.workers.dev/" loading="lazy"></iframe>
        </article>
      </section>

      <section class="module-panel calendar-module" id="calendar">
        <div class="module-heading">
          <div>
            <p class="eyebrow">Calendar menu</p>
            <h2>Release calendar command view</h2>
          </div>
          <span class="module-pill">SPEC-HQ-09 live</span>
        </div>

        <div class="calendar-console" data-calendar-data-url="../../dashboard-data.json">
          <article class="calendar-hero">
            <div>
              <p class="eyebrow">Confluence Team Calendars</p>
              <h3 id="calendar-active-title">GN Releases</h3>
              <p id="calendar-active-summary">Loading release calendar events from the deployed dashboard artifact.</p>
            </div>
            <dl>
              <div>
                <dt>Refresh</dt>
                <dd id="calendar-refresh-cadence">Every 5 min</dd>
              </div>
              <div>
                <dt>Last pull</dt>
                <dd id="calendar-last-pull">Loading</dd>
              </div>
              <div>
                <dt>Window</dt>
                <dd id="calendar-window">Loading</dd>
              </div>
            </dl>
          </article>

          <div class="calendar-toolbar" aria-label="Calendar controls">
            <div class="calendar-view-tabs" role="tablist" aria-label="Calendar display">
              <button class="active" type="button" data-calendar-view="calendar">Calendar</button>
              <button type="button" data-calendar-view="upcoming">Upcoming</button>
            </div>
            <a id="calendar-open-source" class="calendar-open-source" href="https://golfnow.atlassian.net/wiki/display/GQE/calendar/413a852e-d20c-454c-9808-425e167314f2?calendarName=GN%20Releases">Open Confluence calendar</a>
          </div>

          <div class="calendar-alert" id="calendar-alert" hidden></div>

          <div class="calendar-month" id="calendar-month-view" aria-live="polite">
            <div class="calendar-month-heading">
              <div>
                <strong id="calendar-month-title">Release calendar</strong>
                <span class="calendar-month-count" id="calendar-event-count">0 events</span>
              </div>
              <div class="calendar-month-controls" aria-label="Calendar month navigation">
                <button type="button" data-calendar-month="previous" aria-label="Previous month">Prev</button>
                <button type="button" data-calendar-month="today">Today</button>
