---
interface Props {
  title: string;
  dataUrl: string;
  boardRegistryUrl: string;
}

const { title, dataUrl, boardRegistryUrl } = Astro.props;
---

<!doctype html>
<html lang="en" data-dashboard-data-url={dataUrl} data-board-registry-url={boardRegistryUrl}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content="Astro Jira dashboard migration shell" />
    <link rel="icon" href="data:," />
    <title>{title}</title>
  </head>
  <body>
    <a class="skip-link" href="#explorer-heading">Skip to ticket explorer</a>
    <slot />
  </body>
</html>
