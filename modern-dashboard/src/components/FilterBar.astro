<section class="filter-panel" aria-label="Dashboard filters">
  <div class="filter-control search-control">
    <label for="ticket-search">Search</label>
    <input id="ticket-search" type="search" placeholder="Ticket, summary, assignee, component" data-filter="search" />
  </div>
  <div class="filter-control">
    <label for="status-filter">Status</label>
    <select id="status-filter" data-filter="status">
      <option value="">All statuses</option>
    </select>
  </div>
  <div class="filter-control">
    <label for="assignee-filter">Assignee</label>
    <select id="assignee-filter" data-filter="assignee">
      <option value="">All assignees</option>
    </select>
  </div>
  <div class="filter-control">
    <label for="priority-filter">Priority</label>
    <select id="priority-filter" data-filter="priority">
      <option value="">All priorities</option>
    </select>
  </div>
</section>
