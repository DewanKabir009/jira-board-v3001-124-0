<section class="board-hero" aria-labelledby="board-title">
  <div class="board-identity">
    <p class="eyebrow">Release dashboard</p>
    <h1 id="board-title" data-meta="version">Loading board</h1>
    <p class="board-summary" data-meta="summary">Reading the published dashboard data artifact.</p>
    <div class="hero-actions" aria-label="Board links">
      <a class="button-link primary" href="../" data-link="legacy-dashboard">Current board</a>
      <a class="button-link" href="#" data-link="jira-filter">Jira filter</a>
      <a class="button-link" href="#" data-link="bridge-login">Cloudflare bridge</a>
    </div>
  </div>

  <dl class="metric-grid" aria-label="Board metadata">
    <div class="metric-card">
      <dt>Total tickets</dt>
      <dd data-meta="total">0</dd>
    </div>
    <div class="metric-card">
      <dt>Last pull</dt>
      <dd data-meta="pulledAt">Pending</dd>
    </div>
    <div class="metric-card">
      <dt>Data schema</dt>
      <dd data-meta="schema">Unknown</dd>
    </div>
    <div class="metric-card">
      <dt>Bridge</dt>
      <dd data-meta="bridge">Hosted</dd>
    </div>
  </dl>
</section>
